<div style="max-width: 1000px; margin: 0 auto; font-family: 'Inter', system-ui, -apple-system, sans-serif; color: #1e293b;">
  
  <%# --- HEADER --- %>
  <header style="margin-bottom: 25px; display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 15px;">
    <div>
      <h1 style="color: #0f172a; font-size: 2.2em; font-weight: 800; margin: 0; background: linear-gradient(135deg, #1e1b4b, #4338ca); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">
        ¡Hola, <%= current_user.display_name %>! 🎵
      </h1>
      <p style="color: #64748b; font-size: 1.05em; margin: 6px 0 0 0;">Panel de Músico — Control de tus toques, horarios y pagos.</p>
    </div>
    
    <%# --- DEBT BADGE --- %>
    <div style="background: <%= @total_owed > 0 ? '#fffbeb' : '#f0fdf4' %>; border: 1px solid <%= @total_owed > 0 ? '#fde68a' : '#bbf7d0' %>; padding: 12px 20px; border-radius: 16px; text-align: right; box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05);">
      <div style="font-size: 0.85em; font-weight: 700; color: <%= @total_owed > 0 ? '#b45309' : '#15803d' %>; text-transform: uppercase; letter-spacing: 0.05em;">
        <%= @total_owed > 0 ? "Total por Cobrar" : "Cuentas al Día" %>
      </div>
      <div style="font-size: 1.8em; font-weight: 900; color: <%= @total_owed > 0 ? '#d97706' : '#16a34a' %>; margin-top: 2px;">
        <%= number_to_currency(@total_owed, unit: '$') %>
      </div>
    </div>
  </header>

  <%# --- MAIN GRID --- %>
  <div style="display: grid; grid-template-columns: 1fr 340px; gap: 24px; align-items: start;">
    
    <%# --- LEFT COLUMN (MAIN CONTENT) --- %>
    <div style="display: flex; flex-direction: column; gap: 24px;">
      
      <%# --- SECTION 1: NEXT SHOW --- %>
      <section style="background: linear-gradient(135deg, #4f46e5, #3730a3); color: white; padding: 25px; border-radius: 24px; box-shadow: 0 10px 25px -5px rgba(79, 70, 229, 0.3); position: relative; overflow: hidden;">
        <%# Decorative background blur %>
        <div style="position: absolute; top: -50px; right: -50px; width: 150px; height: 150px; background: rgba(255, 255, 255, 0.1); border-radius: 50%; filter: blur(30px);"></div>
        
        <h2 style="margin: 0 0 15px 0; font-size: 1.25em; font-weight: 800; text-transform: uppercase; letter-spacing: 0.05em; color: #e0e7ff; display: flex; align-items: center; gap: 8px;">
          <span>⚡</span> Siguiente Show
        </h2>
        
        <% if @next_gig.present? %>
          <div style="display: flex; flex-direction: column; gap: 15px;">
            <div>
              <div style="font-size: 1.6em; font-weight: 800;"><%= @next_gig.client&.name || 'Evento sin cliente' %></div>
              <div style="font-size: 1.1em; color: #c7d2fe; font-weight: 600; margin-top: 4px;">
                📅 <%= @next_gig.date&.strftime('%A, %d de %B de %Y') rescue 'Fecha no definida' %>
              </div>
            </div>
            
            <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 15px; background: rgba(255, 255, 255, 0.1); padding: 15px; border-radius: 16px; border: 1px solid rgba(255, 255, 255, 0.15);">
              <div>
                <span style="font-size: 0.85em; color: #e0e7ff; display: block; font-weight: 600;">⏰ HORA DE INICIO:</span>
                <strong style="font-size: 1.15em;">
                  <%= @next_gig.start_time.strftime('%I:%M %p') rescue 'No especificada' %>
                </strong>
              </div>
              
              <div>
                <span style="font-size: 0.85em; color: #e0e7ff; display: block; font-weight: 600;">🚗 ESTAR EN EL LUGAR:</span>
                <strong style="font-size: 1.15em;">
                  <% if @next_gig.start_time.present? %>
                    <%= (@next_gig.start_time - 30.minutes).strftime('%I:%M %p') %>
                  <% else %>
                    No especificada
                  <% end %>
                </strong>
              </div>
            </div>
            
            <%# Arrival Advice tip %>
            <div style="background: rgba(254, 243, 199, 0.15); border-left: 4px solid #fbbf24; padding: 12px 16px; border-radius: 8px; font-size: 0.95em; font-weight: 600; color: #fef3c7;">
              💡 <strong>Consejo de llegada:</strong> Se recomienda llegar media hora antes de lo acordado.
            </div>

            <div>
              <span style="font-size: 0.85em; color: #e0e7ff; display: block; font-weight: 600;">📍 UBICACIÓN:</span>
              <div style="font-size: 1.1em; font-weight: 700; margin-top: 4px; display: flex; align-items: center; gap: 6px;">
                <span>🌐</span> <%= @next_gig.location.presence || 'Ubicación no especificada' %>
              </div>
            </div>

            <% if @next_gig.details.present? %>
              <div style="border-top: 1px solid rgba(255, 255, 255, 0.15); padding-top: 12px; font-size: 0.95em; color: #e0e7ff; line-height: 1.5;">
                <strong>Detalles:</strong> <%= truncate(@next_gig.details, length: 180) %>
              </div>
            <% end %>
            
            <div style="margin-top: 5px;">
              <%= link_to 'Ver Detalles Completos del Show', gig_path(@next_gig), style: "display: inline-block; background: white; color: #3730a3; padding: 10px 20px; border-radius: 12px; font-weight: 700; text-decoration: none; font-size: 0.9em; box-shadow: 0 4px 6px rgba(0,0,0,0.1); transition: all 0.2s;" %>
            </div>
          </div>
        <% else %>
          <div style="text-align: center; padding: 20px 0; color: #c7d2fe;">
            <span style="font-size: 2.5em; display: block; margin-bottom: 10px;">🎉</span>
            ¡Sin shows próximos por ahora! Disfruta de tu descanso.
          </div>
        <% end %>
      </section>

      <%# --- SECTION 2: PAYMENTS SUMMARY --- %>
      <section style="background: white; border: 1px solid #e2e8f0; border-radius: 20px; padding: 22px; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.02);">
        <h2 style="margin: 0 0 15px 0; font-size: 1.25em; color: #0f172a; font-weight: 800; display: flex; align-items: center; gap: 8px;">
          <span>💵</span> Cuentas y Pagos por Show
        </h2>

        <div style="display: flex; justify-content: space-between; align-items: center; gap: 16px; flex-wrap: wrap;">
          <div style="display: flex; gap: 28px; flex-wrap: wrap;">
            <div>
              <div style="font-size: 0.75em; color: #94a3b8; font-weight: 700; text-transform: uppercase; letter-spacing: 0.04em; margin-bottom: 4px;">Por Cobrar</div>
              <div style="font-size: 1.8em; font-weight: 900; color: <%= @total_owed > 0 ? '#d97706' : '#16a34a' %>;">
                <%= number_to_currency(@total_owed, unit: '$') %>
              </div>
            </div>
            <div>
              <div style="font-size: 0.75em; color: #94a3b8; font-weight: 700; text-transform: uppercase; letter-spacing: 0.04em; margin-bottom: 4px;">Registros</div>
              <div style="font-size: 1.8em; font-weight: 900; color: #475569;"><%= @employee_payments.count %></div>
            </div>
          </div>
          <%= link_to my_payments_path, style: "text-decoration: none; background: linear-gradient(135deg, #4f46e5, #3730a3); color: white; padding: 12px 22px; border-radius: 12px; font-weight: 700; font-size: 0.9em; white-space: nowrap; box-shadow: 0 4px 12px rgba(79,70,229,0.3);" do %>
            Ver detalle completo →
          <% end %>
        </div>
      </section>
      
    </div>

    <%# --- RIGHT COLUMN (STATS & LISTS) --- %>
    <aside style="display: flex; flex-direction: column; gap: 20px;">
      
      <%# --- ACTIVITY CARD --- %>
      <div style="background: white; border: 1px solid #e2e8f0; border-radius: 20px; padding: 20px; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.02);">
        <h3 style="margin: 0 0 15px 0; font-size: 1.1em; color: #0f172a; font-weight: 800;">Resumen General</h3>
        
        <div style="display: flex; flex-direction: column; gap: 12px;">
          <div style="display: flex; justify-content: space-between; align-items: center; border-bottom: 1px solid #f1f5f9; padding-bottom: 8px;">
            <span style="color: #64748b; font-size: 0.9em;">Total de Shows:</span>
            <strong style="color: #0f172a; font-size: 1.05em;"><%= @assigned_gigs.count %></strong>
          </div>
          
          <div style="display: flex; justify-content: space-between; align-items: center; border-bottom: 1px solid #f1f5f9; padding-bottom: 8px;">
            <span style="color: #64748b; font-size: 0.9em;">Próximos Shows:</span>
            <strong style="color: #4f46e5; font-size: 1.05em;"><%= @proximos_gigs.count %></strong>
          </div>
          
          <div style="display: flex; justify-content: space-between; align-items: center;">
            <span style="color: #64748b; font-size: 0.9em;">Próxima Fecha:</span>
            <strong style="color: #0f172a; font-size: 0.95em;">
              <%= @next_gig.date&.strftime('%d %b %Y') rescue 'Ninguno' %>
            </strong>
          </div>
        </div>
      </div>
      
      <%# --- ASSIGNED GIGS LIST --- %>
      <div style="background: white; border: 1px solid #e2e8f0; border-radius: 20px; padding: 20px; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.02);">
        <h3 style="margin: 0 0 15px 0; font-size: 1.1em; color: #0f172a; font-weight: 800; display: flex; align-items: center; gap: 6px;">
          <span>📋</span> Shows Asignados
        </h3>
        
        <% if @assigned_gigs.present? %>
          <div style="display: flex; flex-direction: column; gap: 12px; max-height: 400px; overflow-y: auto; padding-right: 4px;">
            <% @assigned_gigs.each do |gig| %>
              <% is_upcoming = gig.date >= Date.today rescue false %>
              <div style="padding: 10px; border-radius: 12px; border: 1px solid #f1f5f9; background: <%= is_upcoming ? '#f8fafc' : '#ffffff' %>; transition: transform 0.2s;">
                <div style="display: flex; justify-content: space-between; align-items: start; gap: 4px;">
                  <span style="font-weight: 700; font-size: 0.9em; color: #0f172a; line-height: 1.2;">
                    <%= gig.client&.name || 'Show' %>
                  </span>
                  <span style="font-size: 0.75em; padding: 2px 6px; border-radius: 9999px; font-weight: 700; background: <%= is_upcoming ? '#e0e7ff' : '#f1f5f9' %>; color: <%= is_upcoming ? '#4f46e5' : '#64748b' %>;">
                    <%= is_upcoming ? 'Próximo' : 'Pasado' %>
                  </span>
                </div>
                
                <div style="font-size: 0.8em; color: #64748b; margin-top: 4px;">
                  📅 <%= gig.date&.strftime('%d %b %Y') rescue '' %>
                  <% if gig.start_time.present? %>
                    • ⏰ <%= gig.start_time.strftime('%I:%M %p') %>
                  <% end %>
                </div>
                
                <% if gig.location.present? %>
                  <div style="font-size: 0.8em; color: #94a3b8; margin-top: 2px; text-overflow: ellipsis; overflow: hidden; white-space: nowrap;">
                    📍 <%= gig.location %>
                  </div>
                <% end %>
                
                <div style="margin-top: 6px; text-align: right;">
                  <%= link_to 'Detalles', gig_path(gig), style: "font-size: 0.8em; color: #4f46e5; font-weight: 700; text-decoration: none;" %>
                </div>
              </div>
            <% end %>
          </div>
        <% else %>
          <p style="margin: 0; color: #94a3b8; font-size: 0.9em; font-style: italic; text-align: center;">No tienes shows asignados.</p>
        <% end %>
      </div>

    </aside>
    
  </div>
</div>
