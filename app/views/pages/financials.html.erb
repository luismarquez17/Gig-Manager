<div style="max-width: 1200px; margin: 0 auto; font-family: 'Inter', 'Segoe UI', sans-serif;">

  <%# --- HEADER --- %>
  <header style="margin-bottom: 35px;">
    <h1 style="color: #0f172a; font-size: 2.2em; font-weight: 800; margin: 0; letter-spacing: -0.5px;">📊 Métricas de Negocio y Finanzas</h1>
    <p style="color: #64748b; font-size: 1.1em; margin-top: 5px;">Análisis de facturación, rentabilidad de clientes, locaciones frecuentes e inversión en reparaciones.</p>
  </header>

  <%# --- TARJETAS DE MÉTRICAS CLAVE --- %>
  <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: 20px; margin-bottom: 40px;">
    
    <%# Dinero REALMENTE COBRADO USD %>
    <div style="background: white; padding: 25px; border-radius: 20px; border: 1px solid #e2e8f0; box-shadow: 0 4px 6px rgba(0,0,0,0.01);">
      <span style="color: #64748b; font-weight: 700; font-size: 0.75em; text-transform: uppercase; letter-spacing: 0.5px; display: block; margin-bottom: 8px;">Cobrado Real USD</span>
      <h2 style="font-size: 1.9em; margin: 0; color: #10b981; font-weight: 800;">$ <%= number_with_precision(@total_received_usd, precision: 2) %></h2>
      <div style="font-size: 0.82em; color: #94a3b8; margin-top: 8px; font-weight: 600;">
        🗓️ Presupuesto acordado: $<%= number_with_precision(@budgeted_usd, precision: 2) %> | Proyección: +$<%= number_with_precision(@upcoming_usd, precision: 2) %>
      </div>
    </div>

    <%# Dinero REALMENTE COBRADO BS %>
    <div style="background: white; padding: 25px; border-radius: 20px; border: 1px solid #e2e8f0; box-shadow: 0 4px 6px rgba(0,0,0,0.01);">
      <span style="color: #64748b; font-weight: 700; font-size: 0.75em; text-transform: uppercase; letter-spacing: 0.5px; display: block; margin-bottom: 8px;">Cobrado Real BS</span>
      <h2 style="font-size: 1.9em; margin: 0; color: #3b82f6; font-weight: 800;">Bs <%= number_with_precision(@total_received_bs, precision: 2) %></h2>
      <div style="font-size: 0.82em; color: #94a3b8; margin-top: 8px; font-weight: 600;">
        🗓️ Presupuesto acordado: Bs<%= number_with_precision(@budgeted_bs, precision: 2) %> | Proyección: +Bs <%= number_with_precision(@upcoming_bs, precision: 2) %>
      </div>
    </div>

    <%# Gasto en Mantenimiento %>
    <div style="background: white; padding: 25px; border-radius: 20px; border: 1px solid #e2e8f0; box-shadow: 0 4px 6px rgba(0,0,0,0.01);">
      <span style="color: #64748b; font-weight: 700; font-size: 0.75em; text-transform: uppercase; letter-spacing: 0.5px; display: block; margin-bottom: 8px;">Inversión en Reparaciones</span>
      <h2 style="font-size: 1.9em; margin: 0; color: #e11d48; font-weight: 800;">$ <%= number_with_precision(@total_maintenance_cost, precision: 2) %></h2>
      <div style="font-size: 0.82em; color: #f43f5e; margin-top: 8px; font-weight: 600;">
        ⚠️ Representa el <%= @total_received_usd > 0 ? number_to_percentage((@total_maintenance_cost / @total_received_usd) * 100, precision: 1) : "0%" %> de los ingresos USD cobrados
      </div>
    </div>

    <%# Total Inversiones %>
    <div style="background: white; padding: 25px; border-radius: 20px; border: 1px solid #e2e8f0; box-shadow: 0 4px 6px rgba(0,0,0,0.01);">
      <span style="color: #64748b; font-weight: 700; font-size: 0.75em; text-transform: uppercase; letter-spacing: 0.5px; display: block; margin-bottom: 8px;">Total Invertido (Grupo)</span>
      <h2 style="font-size: 1.9em; margin: 0; color: #8b5cf6; font-weight: 800;">$ <%= number_with_precision(@total_invested_usd, precision: 2) %></h2>
      <div style="font-size: 0.82em; color: #94a3b8; margin-top: 8px; font-weight: 600;">
        💸 <%= link_to "Ver inversiones →", investments_path, style: "color: #8b5cf6; text-decoration: none; font-weight: 700;" %>
      </div>
    </div>

    <%# ROI / Rentabilidad Neta (USD) %>
    <div style="background: white; padding: 25px; border-radius: 20px; border: 1px solid #e2e8f0; box-shadow: 0 4px 6px rgba(0,0,0,0.01);">
      <span style="color: #64748b; font-weight: 700; font-size: 0.75em; text-transform: uppercase; letter-spacing: 0.5px; display: block; margin-bottom: 8px;">Ganancia Neta (ROI USD)</span>
      <h2 style="font-size: 1.9em; margin: 0; color: <%= @net_gain_usd >= 0 ? '#10b981' : '#e11d48' %>; font-weight: 800;">
        <%= @net_gain_usd >= 0 ? '+ ' : '- ' %>$ <%= number_with_precision(@net_gain_usd.abs, precision: 2) %>
      </h2>
      <div style="font-size: 0.82em; color: #94a3b8; margin-top: 8px; font-weight: 600;">
        📈 <%= @total_invested_usd > 0 ? number_to_percentage((@net_gain_usd / @total_invested_usd) * 100, precision: 1) : "—" %> retorno sobre inversión USD
      </div>
    </div>

    <%# ROI / Rentabilidad Neta (BS) %>
    <div style="background: white; padding: 25px; border-radius: 20px; border: 1px solid #e2e8f0; box-shadow: 0 4px 6px rgba(0,0,0,0.01);">
      <span style="color: #64748b; font-weight: 700; font-size: 0.75em; text-transform: uppercase; letter-spacing: 0.5px; display: block; margin-bottom: 8px;">Ganancia Neta (ROI BS)</span>
      <h2 style="font-size: 1.9em; margin: 0; color: <%= @net_gain_bs >= 0 ? '#10b981' : '#e11d48' %>; font-weight: 800;">
        <%= @net_gain_bs >= 0 ? '+ ' : '- ' %>Bs <%= number_with_precision(@net_gain_bs.abs, precision: 2) %>
      </h2>
      <div style="font-size: 0.82em; color: #94a3b8; margin-top: 8px; font-weight: 600;">
        📈 <%= @total_invested_bs > 0 ? number_to_percentage((@net_gain_bs / @total_invested_bs) * 100, precision: 1) : "—" %> retorno sobre inversión BS
      </div>
    </div>

  </div>

  <%# --- ESTADO DE FACTURACIÓN E INVOICE STATUS --- %>
  <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(210px, 1fr)); gap: 20px; margin-bottom: 40px;">
    <div style="background: white; padding: 24px; border-radius: 20px; border: 1px solid #e2e8f0; box-shadow: 0 4px 6px rgba(0,0,0,0.01);">
      <span style="color: #64748b; font-weight: 700; font-size: 0.75em; text-transform: uppercase; letter-spacing: 0.5px; display: block; margin-bottom: 8px;">Shows pagados</span>
      <h2 style="font-size: 1.75em; margin: 0; color: #10b981; font-weight: 800;"><%= @gig_payment_status_counts[:paid] %></h2>
      <div style="font-size: 0.82em; color: #94a3b8; margin-top: 8px; font-weight: 600;">Total de eventos cuyo cobro está completo.</div>
    </div>
    <div style="background: white; padding: 24px; border-radius: 20px; border: 1px solid #e2e8f0; box-shadow: 0 4px 6px rgba(0,0,0,0.01);">
      <span style="color: #64748b; font-weight: 700; font-size: 0.75em; text-transform: uppercase; letter-spacing: 0.5px; display: block; margin-bottom: 8px;">Shows parciales</span>
      <h2 style="font-size: 1.75em; margin: 0; color: #f59e0b; font-weight: 800;"><%= @gig_payment_status_counts[:partial] %></h2>
      <div style="font-size: 0.82em; color: #94a3b8; margin-top: 8px; font-weight: 600;">Eventos con parte del cobro registrado.</div>
    </div>
    <div style="background: white; padding: 24px; border-radius: 20px; border: 1px solid #e2e8f0; box-shadow: 0 4px 6px rgba(0,0,0,0.01);">
      <span style="color: #64748b; font-weight: 700; font-size: 0.75em; text-transform: uppercase; letter-spacing: 0.5px; display: block; margin-bottom: 8px;">Shows pendientes</span>
      <h2 style="font-size: 1.75em; margin: 0; color: #ef4444; font-weight: 800;"><%= @gig_payment_status_counts[:unpaid] %></h2>
      <div style="font-size: 0.82em; color: #94a3b8; margin-top: 8px; font-weight: 600;">Eventos sin cobros registrados.</div>
    </div>
    <div style="background: white; padding: 24px; border-radius: 20px; border: 1px solid #e2e8f0; box-shadow: 0 4px 6px rgba(0,0,0,0.01);">
      <span style="color: #64748b; font-weight: 700; font-size: 0.75em; text-transform: uppercase; letter-spacing: 0.5px; display: block; margin-bottom: 8px;">Total pendiente</span>
      <div style="display: flex; gap: 14px; flex-wrap: wrap; align-items: baseline;">
        <h2 style="font-size: 1.75em; margin: 0; color: #0f172a; font-weight: 800;"><%= number_with_precision(@total_unpaid_amount_by_currency['USD'] || 0, precision: 2) %></h2>
        <span style="color: #64748b; font-weight: 700;">USD</span>
      </div>
      <div style="font-size: 0.82em; color: #94a3b8; margin-top: 8px; font-weight: 600;">Facturas abiertas en USD.</div>
      <div style="margin-top: 8px; font-size: 0.9em; color: #475569; font-weight: 700;">Bs <%= number_with_precision(@total_unpaid_amount_by_currency['BS'] || 0, precision: 2) %> pendiente</div>
    </div>
  </div>

  <% if @top_unpaid_gigs.any? %>
    <div style="background: white; border-radius: 24px; border: 1px solid #e2e8f0; padding: 28px; box-shadow: 0 4px 6px rgba(0,0,0,0.02); margin-bottom: 40px;">
      <h3 style="margin: 0 0 22px 0; font-size: 1.25em; color: #1e293b; font-weight: 800;">🧾 Top Shows con facturas abiertas</h3>
      <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: 16px;">
        <% @top_unpaid_gigs.each do |gig| %>
          <% remaining = gig.amount.to_f - gig.total_received.to_f %>
          <div style="background: #f8fafc; padding: 18px; border-radius: 20px; border: 1px solid #e2e8f0;">
            <div style="display: flex; justify-content: space-between; align-items: center; gap: 12px; margin-bottom: 10px;">
              <div>
                <div style="font-size: 0.9em; font-weight: 800; color: #0f172a;"><%= gig.client.name %></div>
                <div style="font-size: 0.8em; color: #64748b;">Fecha: <%= gig.date&.strftime('%d/%m/%Y') %></div>
              </div>
              <span style="background: #fde68a; color: #92400e; padding: 6px 10px; border-radius: 999px; font-weight: 700; font-size: 0.75em;">Pendiente</span>
            </div>
            <div style="display: flex; justify-content: space-between; align-items: center;">
              <div>
                <div style="font-size: 0.75em; color: #64748b; text-transform: uppercase; font-weight: 700; margin-bottom: 4px;">Monto acordado</div>
                <div style="font-size: 1.1em; font-weight: 800; color: #0f172a;">$ <%= number_with_precision(gig.amount, precision: 2) %></div>
              </div>
              <div style="text-align: right;">
                <div style="font-size: 0.75em; color: #64748b; text-transform: uppercase; font-weight: 700; margin-bottom: 4px;">Saldo</div>
                <div style="font-size: 1.1em; font-weight: 800; color: #ef4444;">$ <%= number_with_precision(remaining, precision: 2) %></div>
              </div>
            </div>
            <div style="margin-top: 12px;">
              <%= link_to 'Ver evento', gig_path(gig), style: 'text-decoration:none; color:#2563eb; font-weight:700;' %>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>

  <div style="background: white; border-radius: 24px; border: 1px solid #e2e8f0; padding: 30px; box-shadow: 0 4px 6px rgba(0,0,0,0.02); margin-bottom: 40px;">
    <h3 style="margin: 0 0 25px 0; font-size: 1.25em; color: #1e293b; font-weight: 800;">📈 Historial de Facturación Mensual</h3>
    
    <% if @monthly_revenue.any? %>
      <div style="display: flex; flex-direction: column; gap: 15px; margin-bottom: 25px;">
        <% 
          # Buscamos el valor máximo mensual para calcular los porcentajes de ancho
          max_val = @monthly_revenue.values.map { |v| v[:usd].to_f }.max
          max_val = 1.0 if max_val == 0
        %>
        <% @monthly_revenue.each do |month, revenue| %>
          <% 
            percent_usd = [(revenue[:usd].to_f / max_val) * 100, 5].max 
          %>
          <div style="display: flex; align-items: center; gap: 20px;">
            <div style="width: 80px; font-weight: 700; color: #475569; font-size: 0.9em; text-align: right;"><%= month %></div>
            <div style="flex-grow: 1; background: #f8fafc; height: 35px; border-radius: 8px; overflow: hidden; display: flex; align-items: center; border: 1px solid #f1f5f9;">
              <div style="width: <%= percent_usd %>%; background: linear-gradient(90deg, #10b981, #34d399); height: 100%; border-radius: 8px; display: flex; align-items: center; padding-left: 12px; box-sizing: border-box; transition: width 0.5s ease-out; box-shadow: 0 2px 4px rgba(16,185,129,0.1);">
                <% if revenue[:usd] > 0 %>
                  <span style="color: white; font-weight: bold; font-size: 0.82em; white-space: nowrap;">$<%= number_with_precision(revenue[:usd], precision: 0) %></span>
                <% end %>
              </div>
            </div>
            <div style="width: 140px; font-size: 0.85em; color: #64748b; font-weight: bold; text-align: left;">
              <% if revenue[:bs] > 0 %>
                Bs <%= number_with_precision(revenue[:bs], precision: 0) %>
              <% else %>
                ---
              <% end %>
            </div>
          </div>
        <% end %>
      </div>
      <div style="display: flex; justify-content: center; gap: 20px; font-size: 0.85em; color: #94a3b8; font-weight: 600;">
        <div style="display: flex; align-items: center; gap: 6px;"><span style="display: inline-block; width: 12px; height: 12px; background: #10b981; border-radius: 3px;"></span> Facturado en USD</div>
      </div>
    <% else %>
      <div style="text-align: center; padding: 40px; color: #94a3b8; font-style: italic;">
        No hay datos suficientes para generar el gráfico.
      </div>
    <% end %>
  </div>

  <%# --- DOS COLUMNAS: CLIENTES Y LOCACIONES --- %>
  <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 30px; margin-bottom: 40px; flex-wrap: wrap;">
    
    <%# Columna 1: Clientes más rentables %>
    <div style="background: white; border-radius: 24px; border: 1px solid #e2e8f0; padding: 30px; box-shadow: 0 4px 6px rgba(0,0,0,0.02);">
      <h3 style="margin: 0 0 20px 0; font-size: 1.2em; color: #1e293b; font-weight: 800; display: flex; align-items: center; gap: 8px;">
        👤 Clientes Clave (Mayor Consumo)
      </h3>
      
      <% if @top_clients.any? %>
        <div style="display: flex; flex-direction: column; gap: 15px;">
          <% @top_clients.each_with_index do |client, index| %>
            <div style="display: flex; justify-content: space-between; align-items: center; padding: 12px 15px; background: #f8fafc; border-radius: 12px; border: 1px solid #f1f5f9;">
              <div style="display: flex; align-items: center; gap: 12px;">
                <span style="background: #e2e8f0; color: #475569; width: 28px; height: 28px; display: flex; align-items: center; justify-content: center; border-radius: 50%; font-weight: 800; font-size: 0.85em;">
                  <%= index + 1 %>
                </span>
                <div>
                  <span style="font-weight: 700; color: #1e293b; font-size: 0.95em;"><%= client.name %></span>
                  <small style="display: block; color: #94a3b8; font-size: 0.8em;"><%= client.gigs_count %> shows agendados</small>
                </div>
              </div>
              <span style="font-weight: bold; color: #10b981; font-size: 1.1em;">
                $ <%= number_with_precision(client.total_spent, precision: 0) %>
              </span>
            </div>
          <% end %>
        </div>
      <% else %>
        <p style="color: #94a3b8; font-style: italic; text-align: center; padding: 20px;">No hay clientes registrados.</p>
      <% end %>
    </div>

    <%# Columna 2: Locaciones más frecuentes %>
    <div style="background: white; border-radius: 24px; border: 1px solid #e2e8f0; padding: 30px; box-shadow: 0 4px 6px rgba(0,0,0,0.02);">
      <h3 style="margin: 0 0 20px 0; font-size: 1.2em; color: #1e293b; font-weight: 800; display: flex; align-items: center; gap: 8px;">
        📍 Locaciones más Frecuentes
      </h3>
      
      <% if @top_locations.any? %>
        <div style="display: flex; flex-direction: column; gap: 15px;">
          <% @top_locations.each_with_index do |(location, count), index| %>
            <div style="display: flex; justify-content: space-between; align-items: center; padding: 12px 15px; background: #f8fafc; border-radius: 12px; border: 1px solid #f1f5f9;">
              <div style="display: flex; align-items: center; gap: 12px;">
                <span style="background: #eff6ff; color: #2563eb; width: 28px; height: 28px; display: flex; align-items: center; justify-content: center; border-radius: 50%; font-weight: 800; font-size: 0.85em;">
                  <%= index + 1 %>
                </span>
                <span style="font-weight: 700; color: #475569; font-size: 0.95em;"><%= location %></span>
              </div>
              <span style="background: #dbeafe; color: #2563eb; padding: 4px 12px; border-radius: 8px; font-weight: bold; font-size: 0.85em;">
                <%= count %> <%= count == 1 ? "show" : "shows" %>
              </span>
            </div>
          <% end %>
        </div>
      <% else %>
        <p style="color: #94a3b8; font-style: italic; text-align: center; padding: 20px;">No hay locaciones registradas.</p>
      <% end %>
    </div>

  </div>

  <%# --- RESUMEN GLOBAL DE FONDOS --- %>
  <div style="background: white; border-radius: 20px; border: 1px solid #e2e8f0; padding: 20px; box-shadow: 0 4px 6px rgba(0,0,0,0.02);">
    <h3 style="margin: 0 0 12px 0; font-size: 1.1em; color: #1e293b; font-weight: 800;">💼 Fondos por Tipo</h3>
    <% if @total_funds_by_type.any? %>
      <div style="display:flex; gap:12px; flex-wrap:wrap;">
        <% @total_funds_by_type.each do |type, total| %>
          <% spent = (@spent_by_type[type] || 0).to_f %>
          <% remaining = total.to_f - spent %>
          <div style="background:#f8fafc; padding:12px; border-radius:10px; border:1px solid #eef2ff; min-width:220px;">
            <div style="font-weight:800; color:#1e293b;"><%= FundAllocation.fund_label_for(type) %></div>
            <div style="margin-top:6px; font-weight:900; color:#0ea5e9;">Asignado: $ <%= number_with_precision(total, precision: 2) %></div>
            <div style="margin-top:4px; color:#ef4444; font-weight:800;">Gastado: $ <%= number_with_precision(spent, precision: 2) %></div>
            <div style="margin-top:6px; font-weight:900; color:#065f46;">Saldo: $ <%= number_with_precision(remaining, precision: 2) %></div>
            <div style="margin-top:8px;"><%= link_to 'Ver detalle', fund_path(type), style: 'text-decoration:none; font-weight:700; color:#2563eb;' %></div>
          </div>
        <% end %>
      </div>
    <% else %>
      <p style="color:#94a3b8;">No hay fondos asignados aún.</p>
    <% end %>
  </div>

</div>
