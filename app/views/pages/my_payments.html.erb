<div style="max-width: 900px; margin: 0 auto; font-family: 'Inter', sans-serif; color: #1e293b;">

  <%# --- HEADER --- %>
  <header style="margin-bottom: 30px;">
    <div style="display: flex; justify-content: space-between; align-items: flex-start; flex-wrap: wrap; gap: 16px;">
      <div>
        <h1 style="font-size: 2em; font-weight: 800; margin: 0; background: linear-gradient(135deg, #1e1b4b, #4338ca); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">
          💵 Cuentas y Pagos por Show
        </h1>
        <p style="color: #64748b; margin-top: 6px; font-size: 1em;">Historial completo de tus pagos y balances por cada evento.</p>
      </div>
      <% if current_user.staff? %>
        <%= link_to root_path, style: "text-decoration: none; padding: 10px 18px; background: #f1f5f9; border-radius: 10px; color: #475569; font-weight: 700; font-size: 0.9em;" do %>
          ← Volver al Dashboard
        <% end %>
      <% elsif current_user.musician? %>
        <%= link_to root_path, style: "text-decoration: none; padding: 10px 18px; background: #f1f5f9; border-radius: 10px; color: #475569; font-weight: 700; font-size: 0.9em;" do %>
          ← Volver al Dashboard
        <% end %>
      <% end %>
    </div>
  </header>

  <%# --- SUMMARY CARDS --- %>
  <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 16px; margin-bottom: 28px;">

    <div style="background: white; border-radius: 16px; padding: 20px; border: 1px solid #e2e8f0; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.03);">
      <div style="font-size: 0.8em; font-weight: 700; color: #64748b; text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 6px;">Total Esperado</div>
      <div style="font-size: 1.8em; font-weight: 900; color: #1e293b;"><%= number_to_currency(@total_expected, unit: '$') %></div>
      <div style="font-size: 0.8em; color: #94a3b8; margin-top: 4px;">Acuerdo total de pagos</div>
    </div>

    <div style="background: white; border-radius: 16px; padding: 20px; border: 1px solid #e2e8f0; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.03);">
      <div style="font-size: 0.8em; font-weight: 700; color: #15803d; text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 6px;">Total Cobrado</div>
      <div style="font-size: 1.8em; font-weight: 900; color: #16a34a;"><%= number_to_currency(@total_paid, unit: '$') %></div>
      <div style="font-size: 0.8em; color: #94a3b8; margin-top: 4px;">Pagos ya recibidos</div>
    </div>

    <div style="background: <%= @total_owed > 0 ? '#fffbeb' : '#f0fdf4' %>; border-radius: 16px; padding: 20px; border: 1px solid <%= @total_owed > 0 ? '#fde68a' : '#bbf7d0' %>; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.03);">
      <div style="font-size: 0.8em; font-weight: 700; color: <%= @total_owed > 0 ? '#b45309' : '#15803d' %>; text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 6px;">
        <%= @total_owed > 0 ? 'Por Cobrar' : 'Al Día' %>
      </div>
      <div style="font-size: 1.8em; font-weight: 900; color: <%= @total_owed > 0 ? '#d97706' : '#16a34a' %>;"><%= number_to_currency(@total_owed, unit: '$') %></div>
      <div style="font-size: 0.8em; color: #94a3b8; margin-top: 4px;">Saldo pendiente</div>
    </div>

    <% paid_count = @employee_payments.select { |p| (p.expected_amount.to_f - p.amount.to_f) <= 0 }.count %>
    <% pending_count = @employee_payments.count - paid_count %>
    <div style="background: white; border-radius: 16px; padding: 20px; border: 1px solid #e2e8f0; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.03);">
      <div style="font-size: 0.8em; font-weight: 700; color: #64748b; text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 6px;">Estado Shows</div>
      <div style="display: flex; gap: 12px; align-items: center; margin-top: 6px;">
        <div style="text-align: center;">
          <div style="font-size: 1.5em; font-weight: 900; color: #16a34a;"><%= paid_count %></div>
          <div style="font-size: 0.75em; color: #94a3b8; font-weight: 600;">Pagados</div>
        </div>
        <div style="width: 1px; height: 32px; background: #e2e8f0;"></div>
        <div style="text-align: center;">
          <div style="font-size: 1.5em; font-weight: 900; color: #d97706;"><%= pending_count %></div>
          <div style="font-size: 0.75em; color: #94a3b8; font-weight: 600;">Pendientes</div>
        </div>
      </div>
    </div>

  </div>

  <%# --- PAYMENTS TABLE --- %>
  <div style="background: white; border-radius: 20px; border: 1px solid #e2e8f0; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.03); overflow: hidden;">
    <div style="padding: 20px 24px; border-bottom: 1px solid #f1f5f9; display: flex; justify-content: space-between; align-items: center;">
      <h2 style="margin: 0; font-size: 1.1em; font-weight: 800; color: #0f172a;">Detalle por Show</h2>
      <span style="font-size: 0.85em; color: #94a3b8;"><%= @employee_payments.count %> registro<%= @employee_payments.count == 1 ? '' : 's' %></span>
    </div>

    <% if @employee_payments.present? %>
      <div style="overflow-x: auto;">
        <table style="width: 100%; border-collapse: collapse; text-align: left; font-size: 0.9em;">
          <thead>
            <tr style="background: #f8fafc; border-bottom: 1px solid #f1f5f9;">
              <th style="padding: 14px 20px; color: #64748b; font-weight: 700; font-size: 0.8em; text-transform: uppercase; letter-spacing: 0.05em;">Evento / Show</th>
              <th style="padding: 14px 12px; text-align: right; color: #64748b; font-weight: 700; font-size: 0.8em; text-transform: uppercase; letter-spacing: 0.05em;">Esperado</th>
              <th style="padding: 14px 12px; text-align: right; color: #64748b; font-weight: 700; font-size: 0.8em; text-transform: uppercase; letter-spacing: 0.05em;">Cobrado</th>
              <th style="padding: 14px 12px; text-align: right; color: #64748b; font-weight: 700; font-size: 0.8em; text-transform: uppercase; letter-spacing: 0.05em;">Pendiente</th>
              <th style="padding: 14px 20px; text-align: center; color: #64748b; font-weight: 700; font-size: 0.8em; text-transform: uppercase; letter-spacing: 0.05em;">Estado</th>
            </tr>
          </thead>
          <tbody>
            <% @employee_payments.each do |payment| %>
              <% pending = payment.expected_amount.to_f - payment.amount.to_f %>
              <tr style="border-bottom: 1px solid #f8fafc; transition: background 0.15s;" onmouseover="this.style.background='#fafbff'" onmouseout="this.style.background='transparent'">
                <td style="padding: 16px 20px; font-weight: 600; color: #0f172a;">
                  <% if payment.gig.present? %>
                    <%= link_to gig_path(payment.gig), style: "color: #4f46e5; text-decoration: none; font-weight: 700; display: flex; flex-direction: column; gap: 2px;" do %>
                      <span style="font-size: 1em;"><%= payment.gig.client&.name || 'Show sin cliente' %></span>
                      <span style="font-size: 0.8em; color: #94a3b8; font-weight: 500;">
                        📅 <%= payment.gig.date&.strftime('%d de %B de %Y') rescue '' %>
                        <% if payment.gig.location.present? %>
                          &nbsp;·&nbsp; 📍 <%= truncate(payment.gig.location, length: 30) %>
                        <% end %>
                      </span>
                    <% end %>
                  <% else %>
                    <span style="color: #475569;">Pago Directo</span>
                    <span style="font-size: 0.8em; color: #94a3b8; font-weight: 500; display: block;">
                      <%= payment.date_paid&.strftime('%d %b %Y') || payment.created_at.strftime('%d %b %Y') %>
                    </span>
                  <% end %>
                </td>

                <td style="padding: 16px 12px; text-align: right; font-weight: 700; color: #475569;">
                  <%= number_to_currency(payment.expected_amount, unit: '$') %>
                </td>

                <td style="padding: 16px 12px; text-align: right; font-weight: 700; color: #16a34a;">
                  <%= number_to_currency(payment.amount, unit: '$') %>
                </td>

                <td style="padding: 16px 12px; text-align: right; font-weight: 800; color: <%= pending > 0 ? '#b45309' : '#16a34a' %>;">
                  <%= number_to_currency(pending, unit: '$') %>
                </td>

                <td style="padding: 16px 20px; text-align: center;">
                  <% if pending <= 0 %>
                    <span style="background: #dcfce7; color: #15803d; padding: 5px 12px; border-radius: 9999px; font-size: 0.78em; font-weight: 800; white-space: nowrap;">✓ Pagado</span>
                  <% elsif payment.amount.to_f > 0 %>
                    <span style="background: #fef3c7; color: #b45309; padding: 5px 12px; border-radius: 9999px; font-size: 0.78em; font-weight: 800; white-space: nowrap;">⏳ Abonado</span>
                  <% else %>
                    <span style="background: #fee2e2; color: #b91c1c; padding: 5px 12px; border-radius: 9999px; font-size: 0.78em; font-weight: 800; white-space: nowrap;">⚠ Pendiente</span>
                  <% end %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>

      <%# --- TOTALS ROW --- %>
      <div style="padding: 16px 20px; background: #f8fafc; border-top: 2px solid #f1f5f9; display: flex; justify-content: flex-end; gap: 32px; flex-wrap: wrap;">
        <div style="text-align: right;">
          <div style="font-size: 0.75em; color: #94a3b8; font-weight: 600; text-transform: uppercase; letter-spacing: 0.04em;">Total Esperado</div>
          <div style="font-size: 1.1em; font-weight: 800; color: #1e293b;"><%= number_to_currency(@total_expected, unit: '$') %></div>
        </div>
        <div style="text-align: right;">
          <div style="font-size: 0.75em; color: #15803d; font-weight: 600; text-transform: uppercase; letter-spacing: 0.04em;">Total Cobrado</div>
          <div style="font-size: 1.1em; font-weight: 800; color: #16a34a;"><%= number_to_currency(@total_paid, unit: '$') %></div>
        </div>
        <div style="text-align: right;">
          <div style="font-size: 0.75em; color: <%= @total_owed > 0 ? '#b45309' : '#15803d' %>; font-weight: 600; text-transform: uppercase; letter-spacing: 0.04em;">Pendiente Total</div>
          <div style="font-size: 1.1em; font-weight: 800; color: <%= @total_owed > 0 ? '#d97706' : '#16a34a' %>;"><%= number_to_currency(@total_owed, unit: '$') %></div>
        </div>
      </div>

    <% else %>
      <div style="padding: 50px 30px; text-align: center; color: #94a3b8;">
        <div style="font-size: 3em; margin-bottom: 12px;">💳</div>
        <div style="font-size: 1.1em; font-weight: 700; color: #64748b; margin-bottom: 6px;">Sin registros de pago</div>
        <div style="font-size: 0.9em;">No hay pagos registrados para tu cuenta por ahora.</div>
      </div>
    <% end %>
  </div>

</div>
