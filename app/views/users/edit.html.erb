<div style="max-width: 600px; margin: 0 auto; font-family: 'Segoe UI', sans-serif;">
  <div style="margin-bottom: 25px;">
    <%= link_to '⬅ Volver a Usuarios', users_path, style: "color: #64748b; text-decoration: none; font-weight: bold; font-size: 0.9em; display: inline-block; margin-bottom: 10px;" %>
    <h1 style="color: #1e293b; margin: 0; font-weight: 800; font-size: 2em; letter-spacing: -0.5px;">👤 Editar Perfil de Trabajador</h1>
    <p style="color: #64748b; margin: 5px 0 0 0;">Configura los datos del trabajador que verá el cliente en su portal.</p>
  </div>

  <div style="background: white; padding: 30px; border-radius: 20px; border: 1px solid #e2e8f0; box-shadow: 0 10px 25px rgba(0,0,0,0.05);">
    <%= form_with(model: @user, local: true) do |f| %>
      
      <% if @user.errors.any? %>
        <div style="background: #fff1f2; border: 1px solid #fca5a5; color: #be123c; padding: 15px; border-radius: 12px; margin-bottom: 20px; font-size: 0.9em;">
          <h4 style="margin: 0 0 8px 0; font-weight: 700;">No se pudo guardar el perfil:</h4>
          <ul style="margin: 0; padding-left: 20px;">
            <% @user.errors.full_messages.each do |message| %>
              <li><%= message %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <%# --- FOTO DE PERFIL / AVATAR --- %>
      <div style="margin-bottom: 25px; text-align: center; background: #f8fafc; padding: 20px; border-radius: 15px; border: 1px dashed #cbd5e1;">
        <div style="margin-bottom: 15px; display: flex; justify-content: center;">
          <% if @user.avatar.attached? %>
            <div style="width: 100px; height: 100px; border-radius: 50%; overflow: hidden; border: 3px solid #2563eb; box-shadow: 0 4px 10px rgba(37, 99, 235, 0.15); display: flex; align-items: center; justify-content: center;">
              <%= image_tag @user.avatar, style: "width: 100%; height: 100%; object-fit: cover;" %>
            </div>
          <% else %>
            <div style="width: 100px; height: 100px; border-radius: 50%; background: linear-gradient(135deg, #2563eb 0%, #0ea5e9 100%); display: flex; align-items: center; justify-content: center; font-size: 2em; font-weight: 800; color: white; border: 3px solid #e2e8f0;">
              <%= @user.display_name[0].upcase %>
            </div>
          <% end %>
        </div>
        <%= f.label :avatar, "📷 Subir Foto de Perfil", style: "display: block; font-weight: bold; color: #475569; margin-bottom: 10px; cursor: pointer;" %>
        <%= f.file_field :avatar, accept: 'image/*', style: "font-size: 0.9em; color: #64748b;" %>
      </div>

      <%# --- NOMBRE --- %>
      <div style="margin-bottom: 20px;">
        <%= f.label :name, "✏️ Nombre Completo", style: "display: block; font-weight: bold; color: #4a5568; margin-bottom: 8px;" %>
        <%= f.text_field :name, placeholder: "Ej: Juan Pérez", style: "width: 100%; padding: 12px; border: 1px solid #cbd5e0; border-radius: 10px; box-sizing: border-box; font-size: 1em;" %>
      </div>

      <%# --- ESPECIALIDAD --- %>
      <div style="margin-bottom: 20px;">
        <%= f.label :specialty, "🎸 Especialidad o Rol", style: "display: block; font-weight: bold; color: #4a5568; margin-bottom: 8px;" %>
        <%= f.text_field :specialty, placeholder: "Ej: DJ Principal, Sonidista, Técnico de Luces, Cantante", style: "width: 100%; padding: 12px; border: 1px solid #cbd5e0; border-radius: 10px; box-sizing: border-box; font-size: 1em;" %>
      </div>

      <%# --- BIO --- %>
      <div style="margin-bottom: 25px;">
        <%= f.label :bio, "📝 Biografía Corta (Mensaje para el Cliente)", style: "display: block; font-weight: bold; color: #4a5568; margin-bottom: 8px;" %>
        <%= f.text_area :bio, rows: 4, placeholder: "Ej: Con más de 8 años de experiencia animando eventos corporativos y bodas. Especialista en música crossover y mezclas en vivo...", style: "width: 100%; padding: 12px; border: 1px solid #cbd5e0; border-radius: 10px; box-sizing: border-box; font-size: 1em; resize: vertical; font-family: inherit;" %>
      </div>

      <div style="display: flex; flex-direction: column; gap: 12px;">
        <%= f.submit "💾 Guardar Perfil", style: "width: 100%; background: #2563eb; color: white; padding: 16px; border: none; border-radius: 12px; font-weight: bold; font-size: 1.1em; cursor: pointer; box-shadow: 0 4px 12px rgba(37, 99, 235, 0.2);" %>
        <%= link_to "🚫 Cancelar", users_path, style: "text-align: center; text-decoration: none; color: #64748b; font-weight: 600; font-size: 0.9em; padding: 10px; border: 1px solid #e2e8f0; border-radius: 12px;" %>
      </div>
    <% end %>
  </div>
</div>
