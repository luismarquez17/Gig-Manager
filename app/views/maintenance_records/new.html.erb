<div style="max-width: 700px; margin: 40px auto; font-family: 'Inter', 'Segoe UI', sans-serif; padding: 0 20px;">
  
  <%= link_to maintenance_records_path, style: "text-decoration: none; color: #64748b; display: flex; align-items: center; gap: 8px; margin-bottom: 25px; font-weight: 600;" do %>
    ← Volver al Taller
  <% end %>

  <% if flash[:alert] %>
    <div style="background: #fff1f2; border: 1px solid #fca5a5; color: #be123c; padding: 15px; border-radius: 12px; margin-bottom: 25px; font-weight: 600;">
      ⚠️ <%= flash[:alert] %>
    </div>
  <% end %>

  <div style="background: white; border-radius: 24px; border: 1px solid #e2e8f0; overflow: hidden; box-shadow: 0 10px 25px -5px rgba(0, 0, 0, 0.05);">
    
    <%# Encabezado %>
    <div style="background: #0f172a; padding: 30px; color: white;">
      <span style="background: #ef4444; padding: 5px 12px; border-radius: 8px; font-size: 0.75em; font-weight: 800; text-transform: uppercase; letter-spacing: 0.5px;">
        ⚠️ Reportar Daño / Desincorporación
      </span>
      <h1 style="margin: 12px 0 0 0; font-size: 1.8em; font-weight: 800;">Reportar Equipo Dañado</h1>
      <p style="margin: 5px 0 0 0; color: #94a3b8; font-size: 0.9em; font-weight: 500;">
        Registra un cable o producto dañado para colocarlo en taller o darlo de baja del inventario.
      </p>
    </div>

    <%# Tabs de Selección de Modo %>
    <div style="display: flex; background: #f8fafc; border-bottom: 1px solid #e2e8f0; padding: 5px 5px 0 5px;">
      <button type="button" id="tab-existing" onclick="switchMode('existing')" 
              style="flex: 1; padding: 15px; border: none; background: white; font-weight: 700; color: #2563eb; cursor: pointer; border-radius: 12px 12px 0 0; border: 1px solid #e2e8f0; border-bottom: none; font-size: 0.95em; transition: 0.2s;">
        📦 Producto Existente
      </button>
      <button type="button" id="tab-new" onclick="switchMode('new')" 
              style="flex: 1; padding: 15px; border: none; background: transparent; font-weight: 700; color: #64748b; cursor: pointer; font-size: 0.95em; border-bottom: 1px solid #e2e8f0; transition: 0.2s;">
        ✨ Registrar Nuevo Producto
      </button>
    </div>

    <div style="padding: 35px;">
      <%= form_with url: maintenance_records_path, method: :post, local: true, id: "report-damage-form" do |f| %>
        <input type="hidden" name="mode" id="form-mode" value="existing">

        <%# ================= SECCIÓN PRODUCTO EXISTENTE ================= %>
        <div id="section-existing" style="display: block; margin-bottom: 25px;">
          <div style="margin-bottom: 20px;">
            <label style="display: block; font-weight: bold; margin-bottom: 8px; color: #475569; font-size: 0.9em;">🔍 Selecciona el Equipo</label>
            <%= select_tag :item_id, 
                options_from_collection_for_select(@items, :id, :name), 
                prompt: "--- Elige un equipo de la lista ---",
                style: "width: 100%; padding: 12px; border: 2px solid #e2e8f0; border-radius: 12px; background: white; outline: none; font-size: 0.95em; color: #1e293b; cursor: pointer; box-sizing: border-box;"
            %>
          </div>

          <div style="margin-bottom: 20px; padding: 15px; border-radius: 12px; background: #f8fafc; border: 1px solid #e2e8f0;">
            <label style="display: block; font-weight: bold; margin-bottom: 10px; color: #475569; font-size: 0.9em;">🔧 Acción sobre el Inventario</label>
            <div style="display: flex; flex-direction: column; gap: 10px;">
              <label style="display: flex; align-items: flex-start; gap: 10px; cursor: pointer; font-size: 0.9em; color: #1e293b;">
                <input type="radio" name="existing_action" value="mark_damaged" checked style="margin-top: 3px;">
                <div>
                  <strong>Marcar unidades existentes como dañadas</strong>
                  <span style="display: block; color: #64748b; font-size: 0.85em; margin-top: 2px;">Usa unidades que ya están registradas en el inventario actual.</span>
                </div>
              </label>
              <label style="display: flex; align-items: flex-start; gap: 10px; cursor: pointer; font-size: 0.9em; color: #1e293b; border-top: 1px solid #e2e8f0; padding-top: 10px;">
                <input type="radio" name="existing_action" value="add_extra" style="margin-top: 3px;">
                <div>
                  <strong>Agregar nuevas unidades dañadas</strong>
                  <span style="display: block; color: #64748b; font-size: 0.85em; margin-top: 2px;">Crea nuevas copias de este equipo en el inventario (incrementa el stock total).</span>
                </div>
              </label>
            </div>
          </div>
        </div>

        <%# ================= SECCIÓN NUEVO PRODUCTO ================= %>
        <div id="section-new" style="display: none; margin-bottom: 25px;">
          <%# Categoría Principal %>
          <div style="margin-bottom: 20px;">
            <label style="display: block; font-weight: bold; margin-bottom: 8px; color: #475569; font-size: 0.9em;">📂 Categoría del Nuevo Equipo</label>
            <%= select_tag :category, 
                options_for_select(Item.categories), 
                prompt: "--- Selecciona tipo de equipo ---",
                id: "category-select", 
                onchange: "updateFormLogic()", 
                style: "width: 100%; padding: 12px; border: 2px solid #e2e8f0; border-radius: 12px; background: white; cursor: pointer; box-sizing: border-box;"
            %>
            
            <div style="margin-top: 8px; font-size: 0.85em;">
              ¿No ves la categoría que necesitas? 
              <a href="javascript:void(0);" onclick="toggleNewCategoryInlineForm();" style="color: #2563eb; font-weight: 600; text-decoration: none;">Crear una nueva categoría aquí</a>
            </div>
            
            <div id="inline-category-form-container" style="display: none; margin-top: 10px; padding: 15px; border-radius: 12px; background: #f8fafc; border: 1px solid #cbd5e1;">
              <p style="margin: 0 0 8px 0; font-size: 0.85em; font-weight: bold; color: #475569;">Crear nueva categoría:</p>
              <div style="display: flex; gap: 8px;">
                <input type="text" id="inline-category-name-input" placeholder="Ej: Cosas adicionales" style="flex-grow: 1; padding: 8px 12px; border: 1px solid #cbd5e1; border-radius: 8px; font-size: 0.9em; outline: none; box-sizing: border-box;">
                <button type="button" onclick="submitNewCategoryInline();" style="background: #10b981; color: white; border: none; padding: 8px 12px; border-radius: 8px; font-weight: bold; cursor: pointer; font-size: 0.9em; transition: 0.2s;">Agregar</button>
              </div>
              <p id="inline-category-error" style="display: none; margin: 5px 0 0 0; font-size: 0.8em; color: #ef4444; font-weight: bold;"></p>
            </div>
          </div>

          <%# Sub-Categoría Dinámica %>
          <div id="sub-category-wrapper" style="display: none; margin-bottom: 20px; padding: 15px; border-radius: 12px; border-width: 1px; border-style: solid;">
            <label id="sub-category-label" style="display: block; font-weight: bold; margin-bottom: 8px; font-size: 0.9em;"></label>
            
            <div id="cables-dropdown" style="display: none;">
              <%= select_tag :sub_category_cable, 
                  options_for_select(Item::CABLE_TYPES), 
                  prompt: "Selecciona tipo de cable...", 
                  class: "sub-select", 
                  style: "width: 100%; padding: 12px; border-radius: 10px; border: 1px solid #3498db; background: white; box-sizing: border-box;"
              %>
            </div>

            <div id="lights-dropdown" style="display: none;">
              <%= select_tag :sub_category_light, 
                  options_for_select(["Cabezal Móvil", "Par Led", "Estrobo", "Láser", "Máquina de Humo"]), 
                  prompt: "Selecciona tipo de luz...", 
                  class: "sub-select", 
                  style: "width: 100%; padding: 12px; border-radius: 10px; border: 1px solid #a855f7; background: white; box-sizing: border-box;"
              %>
            </div>
          </div>

          <%# Nombre del Equipo %>
          <div style="margin-bottom: 20px;">
            <label style="display: block; font-weight: bold; margin-bottom: 8px; color: #475569; font-size: 0.9em;">🏷️ Nombre del Equipo</label>
            <input type="text" name="name" placeholder="Ej: Cable XLR Canon 10 metros" style="width: 100%; padding: 12px; border: 2px solid #e2e8f0; border-radius: 12px; outline: none; font-size: 0.95em; color: #1e293b; box-sizing: border-box;">
          </div>
        </div>

        <%# ================= CAMPOS COMUNES ================= %>
        
        <%# Cantidad e Inicial Status %>
        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-bottom: 20px;">
          <div>
            <label style="display: block; font-weight: bold; margin-bottom: 8px; color: #475569; font-size: 0.9em;">🔢 Cantidad de Unidades</label>
            <input type="number" name="quantity" value="1" min="1" style="width: 100%; padding: 12px; border: 2px solid #e2e8f0; border-radius: 12px; outline: none; font-size: 0.95em; color: #1e293b; box-sizing: border-box;">
          </div>
          <div>
            <label style="display: block; font-weight: bold; margin-bottom: 8px; color: #475569; font-size: 0.9em;">⚙️ Destino del Reporte</label>
            <select name="initial_status" id="initial-status-select" onchange="updateAvisoTirro()" style="width: 100%; padding: 12px; border: 2px solid #e2e8f0; border-radius: 12px; background: white; outline: none; font-size: 0.95em; font-weight: 600; color: #1e293b; cursor: pointer; box-sizing: border-box;">
              <option value="pending">⏳ Enviar al Taller (Pendiente)</option>
              <option value="discarded">🗑️ Pérdida Total (Desincorporar)</option>
            </select>
          </div>
        </div>

        <%# Fecha %>
        <div style="margin-bottom: 20px;">
          <label style="display: block; font-weight: bold; margin-bottom: 8px; color: #475569; font-size: 0.9em;">📅 Fecha del Suceso</label>
          <input type="date" name="started_at" value="<%= Date.today %>" style="width: 100%; padding: 12px; border: 2px solid #e2e8f0; border-radius: 12px; outline: none; font-size: 0.95em; color: #1e293b; box-sizing: border-box;">
        </div>

        <%# Descripción del Daño / Pérdida %>
        <div style="margin-bottom: 25px;">
          <label style="display: block; font-weight: bold; margin-bottom: 8px; color: #475569; font-size: 0.9em;">📝 Notas / Descripción del Daño o Motivo</label>
          <textarea name="description" rows="3" placeholder="Ej. Se cortó el cable en el show, o se perdió el conector..." style="width: 100%; padding: 12px; border: 2px solid #e2e8f0; border-radius: 12px; font-size: 0.95em; font-family: inherit; resize: vertical; box-sizing: border-box; outline: none; transition: 0.2s;"></textarea>
        </div>

        <%# AVISO DE TIRRO %>
        <div id="damage-notice" style="display: none; margin-bottom: 25px; background: #fff1f2; border: 2px dashed #f43f5e; padding: 15px; border-radius: 12px; text-align: center;">
          <p style="margin: 0; color: #e11d48; font-weight: 800; text-transform: uppercase; font-size: 0.85em;">
            ⚠️ RECORDATORIO: MARCAR FÍSICAMENTE CON TIRRO ROJO / DAÑADO ANTES DE GUARDAR
          </p>
        </div>

        <div id="lost-notice" style="display: none; margin-bottom: 25px; background: #fff7ed; border: 2px dashed #f97316; padding: 15px; border-radius: 12px; text-align: center;">
          <p style="margin: 0; color: #ea580c; font-weight: 800; text-transform: uppercase; font-size: 0.85em;">
            🗑️ SE DESCONTARÁ DIRECTAMENTE DE LA CANTIDAD TOTAL EN INVENTARIO
          </p>
        </div>

        <%# Botones de Envío %>
        <div style="display: flex; gap: 15px;">
          <%= link_to "Cancelar", maintenance_records_path, 
              style: "flex: 1; text-align: center; text-decoration: none; background: #f1f5f9; color: #475569; padding: 15px; border-radius: 12px; font-weight: bold; transition: 0.2s; border: 1px solid #cbd5e1;",
              onmouseover: "this.style.background='#e2e8f0'",
              onmouseout: "this.style.background='#f1f5f9'" %>
          
          <button type="submit" style="flex: 2; background: #ef4444; color: white; border: none; padding: 15px; border-radius: 12px; font-weight: bold; cursor: pointer; font-size: 1em; transition: 0.2s; box-shadow: 0 4px 10px rgba(239,68,68,0.2);"
                  onmouseover: "this.style.backgroundColor='#dc2626'"
                  onmouseout: "this.style.backgroundColor='#ef4444'">
            💾 Registrar Reporte
          </button>
        </div>
      <% end %>
    </div>

  </div>

</div>

<script>
  function switchMode(mode) {
    document.getElementById('form-mode').value = mode;
    
    var tabExisting = document.getElementById('tab-existing');
    var tabNew = document.getElementById('tab-new');
    var secExisting = document.getElementById('section-existing');
    var secNew = document.getElementById('section-new');

    if (mode === 'existing') {
      tabExisting.style.background = 'white';
      tabExisting.style.color = '#2563eb';
      tabExisting.style.borderBottom = 'none';
      tabExisting.style.border = '1px solid #e2e8f0';
      tabExisting.style.borderBottom = 'none';

      tabNew.style.background = 'transparent';
      tabNew.style.color = '#64748b';
      tabNew.style.border = 'none';
      tabNew.style.borderBottom = '1px solid #e2e8f0';

      secExisting.style.display = 'block';
      secNew.style.display = 'none';
    } else {
      tabNew.style.background = 'white';
      tabNew.style.color = '#2563eb';
      tabNew.style.border = '1px solid #e2e8f0';
      tabNew.style.borderBottom = 'none';

      tabExisting.style.background = 'transparent';
      tabExisting.style.color = '#64748b';
      tabExisting.style.border = 'none';
      tabExisting.style.borderBottom = '1px solid #e2e8f0';

      secExisting.style.display = 'none';
      secNew.style.display = 'block';
    }
  }

  function updateFormLogic() {
    const categorySelect = document.getElementById('category-select');
    if (!categorySelect) return;
    const category = categorySelect.value;
    
    const wrapper = document.getElementById('sub-category-wrapper');
    const label = document.getElementById('sub-category-label');
    const cableDiv = document.getElementById('cables-dropdown');
    const lightDiv = document.getElementById('lights-dropdown');

    if (!wrapper || !label || !cableDiv || !lightDiv) return;

    // Reset
    wrapper.style.display = "none";
    cableDiv.style.display = "none";
    lightDiv.style.display = "none";

    if (category === "Cables") {
      wrapper.style.display = "block";
      wrapper.style.backgroundColor = "#f0f9ff";
      wrapper.style.borderColor = "#bae6fd";
      label.innerText = "🔌 Tipo de Cable";
      label.style.color = "#0369a1";
      cableDiv.style.display = "block";
    } else if (category === "Luces") {
      wrapper.style.display = "block";
      wrapper.style.backgroundColor = "#faf5ff";
      wrapper.style.borderColor = "#e9d5ff";
      label.innerText = "💡 Tipo de Iluminación";
      label.style.color = "#6b21a8";
      lightDiv.style.display = "block";
    }
  }

  function updateAvisoTirro() {
    var statusSelect = document.getElementById('initial-status-select');
    var damageNotice = document.getElementById('damage-notice');
    var lostNotice = document.getElementById('lost-notice');
    
    if (statusSelect.value === 'pending') {
      damageNotice.style.display = 'block';
      lostNotice.style.display = 'none';
    } else {
      damageNotice.style.display = 'none';
      lostNotice.style.display = 'block';
    }
  }

  function toggleNewCategoryInlineForm() {
    var container = document.getElementById('inline-category-form-container');
    if (container.style.display === 'none') {
      container.style.display = 'block';
      document.getElementById('inline-category-name-input').focus();
    } else {
      container.style.display = 'none';
    }
  }

  function submitNewCategoryInline() {
    var input = document.getElementById('inline-category-name-input');
    var name = input.value.trim();
    var errorLabel = document.getElementById('inline-category-error');
    if (!name) return;

    errorLabel.style.display = 'none';
    var csrfToken = document.querySelector('meta[name="csrf-token"]').getAttribute('content');

    fetch('/categories', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'X-CSRF-Token': csrfToken,
        'Accept': 'application/json'
      },
      body: JSON.stringify({ category: { name: name } })
    })
    .then(response => response.json())
    .then(data => {
      if (data.success) {
        var select = document.getElementById('category-select');
        var option = document.createElement('option');
        option.value = data.category.name;
        option.text = data.category.name;
        select.add(option);
        select.value = data.category.name;
        input.value = '';
        toggleNewCategoryInlineForm();
        updateFormLogic();
      } else {
        errorLabel.innerText = data.errors.join(', ');
        errorLabel.style.display = 'block';
      }
    })
    .catch(error => {
      errorLabel.innerText = 'Error al crear la categoría.';
      errorLabel.style.display = 'block';
      console.error(error);
    });
  }

  // Inicializar
  document.addEventListener("turbo:load", function() {
    updateFormLogic();
    updateAvisoTirro();
  });
  document.addEventListener("DOMContentLoaded", function() {
    updateFormLogic();
    updateAvisoTirro();
  });
</script>
