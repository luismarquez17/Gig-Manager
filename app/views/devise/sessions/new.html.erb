<div style="min-height: 80vh; display: flex; align-items: center; justify-content: center; font-family: 'Inter', sans-serif;">
  <div style="background: white; padding: 40px; border-radius: 24px; border: 1px solid #e2e8f0; box-shadow: 0 20px 25px -5px rgba(0,0,0,0.1); width: 100%; max-width: 400px;">
    
    <%# Logo y Título %>
    <div style="text-align: center; margin-bottom: 30px;">
      <div style="background: #2563eb; color: white; width: 50px; height: 50px; display: flex; align-items: center; justify-content: center; border-radius: 12px; font-size: 1.5em; font-weight: 800; margin: 0 auto 15px auto;">G</div>
      <h2 style="color: #0f172a; margin: 0; font-size: 1.8em; font-weight: 800;">Bienvenido</h2>
      <p style="color: #64748b; font-size: 0.9em; margin-top: 5px;">Ingresa tus credenciales para continuar</p>
    </div>

    <%= form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>
      <div style="margin-bottom: 20px;">
        <%= f.label :email, "Correo Electrónico", style: "display: block; font-size: 0.85em; font-weight: 700; color: #475569; margin-bottom: 8px;" %>
        <%= f.email_field :email, autofocus: true, autocomplete: "email", placeholder: "ejemplo@familia.com", 
            style: "width: 100%; padding: 12px 15px; border-radius: 10px; border: 1px solid #e2e8f0; outline: none; box-sizing: border-box; font-size: 0.95em;" %>
      </div>

      <div style="margin-bottom: 20px;">
        <%= f.label :password, "Contraseña", style: "display: block; font-size: 0.85em; font-weight: 700; color: #475569; margin-bottom: 8px;" %>
        <%= f.password_field :password, autocomplete: "current-password", placeholder: "••••••••",
            style: "width: 100%; padding: 12px 15px; border-radius: 10px; border: 1px solid #e2e8f0; outline: none; box-sizing: border-box; font-size: 0.95em;" %>
      </div>

      <% if devise_mapping.rememberable? %>
        <div style="display: flex; align-items: center; gap: 8px; margin-bottom: 25px;">
          <%= f.check_box :remember_me, style: "width: 16px; height: 16px; accent-color: #2563eb;" %>
          <%= f.label :remember_me, "Recordarme", style: "font-size: 0.85em; color: #64748b; font-weight: 600;" %>
        </div>
      <% end %>

      <%= f.submit "Iniciar Sesión", style: "width: 100%; background: #0f172a; color: white; padding: 14px; border: none; border-radius: 12px; font-weight: 700; font-size: 1em; cursor: pointer; transition: 0.3s; box-shadow: 0 4px 6px rgba(0,0,0,0.1);" %>
    <% end %>

    <div style="margin-top: 25px; text-align: center; border-top: 1px solid #f1f5f9; padding-top: 20px;">
      <%= render "devise/shared/links" %>
    </div>
  </div>
</div>