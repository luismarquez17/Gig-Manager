<div style="max-width:700px; margin:40px auto; font-family: 'Inter',sans-serif;">
  <div style="background: white; padding: 28px; border-radius: 12px; border: 1px solid #e6eef8; box-shadow: 0 6px 20px rgba(2,6,23,0.06);">
    <h1 style="margin:0 0 12px 0; font-size:24px; color:#0f172a;">Editar Perfil</h1>
    <p style="margin:0 0 20px 0; color:#64748b;">Actualiza tu correo o contraseña. Deja los campos de contraseña en blanco si no quieres cambiarla.</p>

    <%= devise_error_messages! %>

    <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { method: :put, style: 'display:flex; flex-direction:column; gap:14px;' }) do |f| %>

      <div style="display:flex; flex-direction:column; gap:6px;">
        <label style="font-weight:700; color:#0f172a;">Email</label>
        <%= f.email_field :email, autofocus: true, autocomplete: "email", style: 'padding:10px 12px; border-radius:8px; border:1px solid #e6eef8; background:#fbfdff; width:100%;' %>
      </div>

      <div style="display:flex; flex-direction:column; gap:6px;">
        <label style="font-weight:700; color:#0f172a;">Password <span style="font-weight:600; color:#94a3b8; font-size:0.9em;">(dejar en blanco para no cambiar)</span></label>
        <%= f.password_field :password, autocomplete: "new-password", style: 'padding:10px 12px; border-radius:8px; border:1px solid #e6eef8; background:#fbfdff; width:100%;' %>
      </div>

      <div style="display:flex; flex-direction:column; gap:6px;">
        <label style="font-weight:700; color:#0f172a;">Confirmar Password</label>
        <%= f.password_field :password_confirmation, autocomplete: "new-password", style: 'padding:10px 12px; border-radius:8px; border:1px solid #e6eef8; background:#fbfdff; width:100%;' %>
      </div>

      <div style="display:flex; flex-direction:column; gap:6px;">
        <label style="font-weight:700; color:#0f172a;">Contraseña Actual <span style="font-weight:600; color:#94a3b8; font-size:0.9em;">(necesaria para confirmar cambios)</span></label>
        <%= f.password_field :current_password, autocomplete: "current-password", style: 'padding:10px 12px; border-radius:8px; border:1px solid #e6eef8; background:#fbfdff; width:100%;' %>
      </div>

      <div style="display:flex; gap:12px; align-items:center; margin-top:6px;">
        <%= f.submit "Actualizar", style: 'background:#2563eb; color:white; padding:10px 16px; border-radius:10px; border:none; font-weight:700; cursor:pointer; box-shadow:0 8px 24px rgba(37,99,235,0.12);' %>
        <%= link_to "Volver", root_path, style: 'padding:10px 14px; border-radius:10px; text-decoration:none; color:#2563eb; border:1px solid #e6eef8;' %>
      </div>
    <% end %>

    <hr style="margin:22px 0; border:none; border-top:1px solid #f1f5f9;" />

    <div>
      <h3 style="margin:0 0 8px 0; font-size:16px; color:#0f172a;">Cancelar mi cuenta</h3>
      <p style="margin:0 0 8px 0; color:#64748b;">Si estás seguro, puedes cancelar tu cuenta permanentemente.</p>
      <%= button_to "Cancelar mi cuenta", registration_path(resource_name), method: :delete, data: { confirm: "¿Estás seguro? Esta acción no puede deshacerse." }, style: 'background:#fff1f2; color:#9f1239; padding:10px 14px; border-radius:10px; border:1px solid #fdecea; font-weight:700; cursor:pointer;' %>
    </div>
  </div>
</div>
 
