  <% end %>

  <%# --- FOOTER --- %>
  <footer style="text-align: center; color: var(--text-muted); font-size: 0.85em; margin-top: 50px; border-top: 1px solid rgba(255,255,255,0.05); padding-top: 20px;">
    <p style="margin: 0;">Generado por <strong>Gig Manager</strong>. Todos los derechos reservados.</p>
  </footer>

</div>

<%# --- JAVASCRIPT --- %>
<script>
  // 1. Lógica de la cuenta regresiva
  (function() {
    const gigDateStr = '<%= @gig.date&.to_s %>';
    if (!gigDateStr) return;

    // Supongamos que el show empieza a las 20:00 (8:00 PM) por defecto de ese día
    const targetDate = new Date(`${gigDateStr}T20:00:00`).getTime();
    const lblElement = document.getElementById('countdown-label');

    const updateCountdown = () => {
      const now = new Date().getTime();
      const diff = targetDate - now;

      if (diff <= 0) {
        // El evento ya pasó o es hoy
        const eventDayStart = new Date(`${gigDateStr}T00:00:00`).getTime();
        const eventDayEnd = new Date(`${gigDateStr}T23:59:59`).getTime();
        const currentNow = new Date().getTime();

        if (currentNow >= eventDayStart && currentNow <= eventDayEnd) {
          // Es hoy!
          document.getElementById('cd-days').textContent = '🎉';
          document.getElementById('cd-hours').textContent = '🎸';
          document.getElementById('cd-minutes').textContent = '🔥';
          document.getElementById('cd-seconds').textContent = '⚡';
          lblElement.textContent = "¡TU EVENTO ES HOY! ¡A DISFRUTAR!";
          lblElement.style.color = "#10b981";
        } else {
          // Evento finalizado
          document.getElementById('cd-days').textContent = '00';
          document.getElementById('cd-hours').textContent = '00';
          document.getElementById('cd-minutes').textContent = '00';
          document.getElementById('cd-seconds').textContent = '00';
          lblElement.textContent = "¡Evento Finalizado! Gracias por tu preferencia.";
          lblElement.style.color = '#94a3b8';
        }
        clearInterval(timerInterval);
        return;
      }

      // Cálculos de tiempo
      const days = Math.floor(diff / (1000 * 60 * 60 * 24));
      const hours = Math.floor((diff % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
      const minutes = Math.floor((diff % (1000 * 60 * 60)) / (1000 * 60));
      const seconds = Math.floor((diff % (1000 * 60)) / 1000);

      // Formatear dos dígitos
      document.getElementById('cd-days').textContent = days.toString().padStart(2, '0');
      document.getElementById('cd-hours').textContent = hours.toString().padStart(2, '0');
      document.getElementById('cd-minutes').textContent = minutes.toString().padStart(2, '0');
      document.getElementById('cd-seconds').textContent = seconds.toString().padStart(2, '0');
    };

    updateCountdown();
    const timerInterval = setInterval(updateCountdown, 1000);
  })();

  // 2. Firma digital por AJAX
  function submitContractSignature() {
    const sigInput = document.getElementById('signature-input');
    const signatureName = sigInput.value.trim();
    
    if (!signatureName) {
      sigInput.style.borderColor = 'var(--danger)';
      alert("Por favor, escribe tu nombre completo para poder firmar.");
      return;
    }

    const btn = document.getElementById('btn-sign-contract');
    btn.disabled = true;
    btn.textContent = "Firmando Contrato...";

    const token = '<%= params[:token] %>';
    const csrfToken = document.querySelector('meta[name="csrf-token"]')?.getAttribute('content') || '';

    fetch(`/portal/${token}/sign`, {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'X-CSRF-Token': csrfToken,
        'Accept': 'application/json'
      },
      body: JSON.stringify({ signature_name: signatureName })
    })
    .then(res => res.json())
    .then(data => {
      if (data.success) {
        // Reemplazar sección de firma por la tarjeta firmada
        const signatureSection = document.getElementById('signature-section');
        signatureSection.innerHTML = `
          <div class="signed-badge" style="animation: scaleIn 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path>
              <polyline points="22 4 12 14.01 9 11.01"></polyline>
            </svg>
            <div class="signed-details">
              <h4 style="margin: 0 0 5px 0; font-size: 1.05em; font-weight: 800;">Contrato Firmado Digitalmente</h4>
              <p><strong>Firmante:</strong> ${data.name}</p>
              <p><strong>Fecha/Hora:</strong> ${data.signed_at}</p>
              <p><strong>IP de Registro:</strong> ${data.ip}</p>
            </div>
          </div>
        `;
      } else {
        alert("Error al firmar contrato: " + (data.error || "Ocurrió un error."));
        btn.disabled = false;
        btn.textContent = "✍️ Aceptar Términos y Firmar Contrato";
      }
    })
    .catch(() => {
      alert("Error de red. Intenta de nuevo.");
      btn.disabled = false;
      btn.textContent = "✍️ Aceptar Términos y Firmar Contrato";
    });
  }
</script>

<style>
  /* CSS Animations */
  @keyframes scaleIn {
    0% { transform: scale(0.9); opacity: 0; }
    100% { transform: scale(1); opacity: 1; }
  }
</style>
