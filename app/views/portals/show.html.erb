<style>
  /* Glassmorphism card styles */
  .glass-card {
    background: var(--card-bg);
    border: 1px solid var(--card-border);
    backdrop-filter: blur(16px) saturate(120%);
    -webkit-backdrop-filter: blur(16px) saturate(120%);
    border-radius: 24px;
    padding: 30px;
    margin-bottom: 30px;
    box-shadow: 0 8px 32px 0 rgba(0, 0, 0, 0.3);
    transition: border-color 0.3s ease, box-shadow 0.3s ease, transform 0.3s ease;
  }
  .glass-card:hover {
    border-color: var(--card-border-hover);
    box-shadow: 0 12px 40px 0 rgba(139, 92, 246, 0.15);
    transform: translateY(-2px);
  }

  /* Typography helpers */
  .title-accent {
    background: linear-gradient(135deg, #a78bfa 0%, #22d3ee 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    font-family: var(--font-outfit);
    font-weight: 800;
  }

  /* Header Styles */
  .portal-header {
    text-align: center;
    margin-bottom: 40px;
    position: relative;
  }
  .portal-header .badge {
    background: rgba(139, 92, 246, 0.15);
    border: 1px solid rgba(139, 92, 246, 0.3);
    color: #c084fc;
    padding: 6px 16px;
    border-radius: 99px;
    font-size: 0.85em;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    display: inline-block;
    margin-bottom: 15px;
  }
  .portal-header h1 {
    font-size: 2.8em;
    margin: 0 0 10px 0;
    line-height: 1.2;
    letter-spacing: -1px;
  }
  .portal-header p {
    color: var(--text-muted);
    font-size: 1.1em;
    margin: 0;
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 8px;
    flex-wrap: wrap;
  }

  /* Countdown grid */
  .countdown-container {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 15px;
    text-align: center;
    margin-top: 10px;
  }
  .countdown-box {
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.05);
    border-radius: 16px;
    padding: 15px 10px;
  }
  .countdown-box .val {
    font-family: var(--font-outfit);
    font-size: 2.5em;
    font-weight: 800;
    line-height: 1;
    margin-bottom: 5px;
    background: linear-gradient(180deg, #ffffff 0%, #cbd5e1 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }
  .countdown-box .lbl {
    color: var(--text-muted);
    font-size: 0.75em;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1px;
  }
  .countdown-title {
    text-align: center;
    font-family: var(--font-outfit);
    font-size: 1.1em;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 2px;
    color: #a78bfa;
    margin-bottom: 20px;
  }

  @media (max-width: 500px) {
    .countdown-container {
      grid-template-columns: repeat(2, 1fr);
    }
    .countdown-box .val {
      font-size: 2em;
    }
  }

  /* Section Headings */
  .section-title {
    font-family: var(--font-outfit);
    font-size: 1.4em;
    font-weight: 800;
    color: var(--text-main);
    margin: 0 0 20px 0;
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .section-title span.icon {
    background: var(--primary-glow);
    border: 1px solid rgba(139, 92, 246, 0.2);
    width: 36px;
    height: 36px;
    border-radius: 10px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: 0.9em;
    color: #c084fc;
  }

  /* Finance dashboard styles */
  .finance-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
    margin-bottom: 25px;
  }
  .finance-card {
    background: rgba(255, 255, 255, 0.02);
    border: 1px solid rgba(255, 255, 255, 0.05);
    border-radius: 16px;
    padding: 20px;
  }
  .finance-card .lbl {
    font-size: 0.8em;
    font-weight: 700;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.5px;
    margin-bottom: 8px;
  }
  .finance-card .val {
    font-family: var(--font-outfit);
    font-size: 1.6em;
    font-weight: 800;
  }
  .finance-card.val-total .val { color: var(--text-main); }
  .finance-card.val-paid .val { color: var(--success); }
  .finance-card.val-remaining .val { color: var(--warning); }

  @media (max-width: 600px) {
    .finance-grid {
      grid-template-columns: 1fr;
      gap: 15px;
    }
  }

  /* Progress Bar */
  .progress-container {
    margin-bottom: 30px;
  }
  .progress-header {
    display: flex;
    justify-content: space-between;
    font-size: 0.9em;
    font-weight: 700;
    margin-bottom: 8px;
  }
  .progress-track {
    background: rgba(255, 255, 255, 0.06);
    height: 12px;
    border-radius: 99px;
    overflow: hidden;
    position: relative;
    border: 1px solid rgba(255, 255, 255, 0.03);
  }
  .progress-fill {
    height: 100%;
    background: linear-gradient(90deg, var(--primary) 0%, #06b6d4 100%);
    border-radius: 99px;
    box-shadow: 0 0 12px var(--primary-glow);
    transition: width 1s ease-in-out;
  }

  /* Table styling */
  .table-wrapper {
    overflow-x: auto;
    border-radius: 16px;
    border: 1px solid rgba(255, 255, 255, 0.05);
    background: rgba(0, 0, 0, 0.15);
  }
  .portal-table {
    width: 100%;
    border-collapse: collapse;
    text-align: left;
  }
  .portal-table th {
    background: rgba(255, 255, 255, 0.02);
    padding: 14px 18px;
    color: var(--text-muted);
    font-weight: 700;
    font-size: 0.85em;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
  }
  .portal-table td {
    padding: 14px 18px;
    border-bottom: 1px solid rgba(255, 255, 255, 0.04);
    font-size: 0.95em;
  }
  .portal-table tr:last-child td {
    border-bottom: none;
  }

  /* Timeline Styles */
  .timeline-container {
    position: relative;
    padding-left: 30px;
    margin-left: 10px;
  }
  .timeline-container::before {
    content: '';
    position: absolute;
    left: 0;
    top: 5px;
    bottom: 5px;
    width: 2px;
    background: linear-gradient(180deg, var(--primary) 0%, rgba(6, 182, 212, 0.3) 100%);
  }
  .timeline-item {
    position: relative;
    margin-bottom: 25px;
  }
  .timeline-item:last-child {
    margin-bottom: 0;
  }
  .timeline-dot {
    position: absolute;
    left: -35px;
    top: 5px;
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background: var(--bg-dark);
    border: 3px solid var(--primary);
    box-shadow: 0 0 8px var(--primary);
  }
  .timeline-time {
    font-family: var(--font-outfit);
    font-weight: 800;
    color: #c084fc;
    font-size: 0.9em;
    margin-bottom: 4px;
    text-transform: uppercase;
  }
  .timeline-title {
    font-weight: 700;
    font-size: 1.1em;
    color: var(--text-main);
    margin-bottom: 6px;
  }
  .timeline-desc {
    color: var(--text-muted);
    font-size: 0.9em;
    line-height: 1.4;
  }

  /* Contract Signature panel */
  .contract-content {
    background: rgba(0, 0, 0, 0.15);
    border: 1px solid rgba(255, 255, 255, 0.04);
    border-radius: 16px;
    padding: 20px;
    max-height: 250px;
    overflow-y: auto;
    font-size: 0.95em;
    line-height: 1.6;
    color: #cbd5e1;
    margin-bottom: 20px;
    white-space: pre-line;
  }
  
  .signature-box {
    background: rgba(139, 92, 246, 0.04);
    border: 1px dashed rgba(139, 92, 246, 0.2);
    border-radius: 16px;
    padding: 20px;
    margin-top: 15px;
  }
  
  .signed-badge {
    background: rgba(16, 185, 129, 0.1);
    border: 1px solid rgba(16, 185, 129, 0.3);
    color: #34d399;
    border-radius: 16px;
    padding: 20px;
    display: flex;
    align-items: center;
    gap: 15px;
  }
  
  .signed-badge svg {
    flex-shrink: 0;
    color: var(--success);
  }
  
  .signed-details p {
    margin: 2px 0;
    font-size: 0.9em;
  }
  
  /* Input & Button styling */
  .form-input {
    width: 100%;
    padding: 12px 16px;
    border: 1px solid rgba(255, 255, 255, 0.1);
    background: rgba(0, 0, 0, 0.2);
    border-radius: 12px;
    color: white;
    font-family: inherit;
    font-size: 1em;
    box-sizing: border-box;
    outline: none;
    margin-bottom: 12px;
    transition: border-color 0.3s;
  }
  .form-input:focus {
    border-color: var(--primary);
  }
  
  .btn-portal {
    background: linear-gradient(135deg, var(--primary) 0%, var(--primary-hover) 100%);
    color: white;
    border: none;
    padding: 12px 24px;
    border-radius: 12px;
    font-weight: 700;
    cursor: pointer;
    font-size: 1em;
    width: 100%;
    transition: transform 0.2s, box-shadow 0.2s;
    box-shadow: 0 4px 12px var(--primary-glow);
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
  }
  .btn-portal:hover {
    transform: translateY(-1px);
    box-shadow: 0 6px 18px var(--primary-glow);
  }
  .btn-portal:active {
    transform: translateY(0);
  }
  .btn-portal:disabled {
    background: #475569;
    color: #94a3b8;
    cursor: not-allowed;
    box-shadow: none;
  }

  .btn-whatsapp {
    background: linear-gradient(135deg, #25d366 0%, #128c7e 100%);
    box-shadow: 0 4px 12px rgba(37, 211, 102, 0.2);
  }
  .btn-whatsapp:hover {
    box-shadow: 0 6px 18px rgba(37, 211, 102, 0.3);
  }

  .alert-warning {
    background: rgba(245, 158, 11, 0.08);
    border: 1px solid rgba(245, 158, 11, 0.2);
    color: #fbd38d;
    padding: 12px 16px;
    border-radius: 12px;
    margin-bottom: 15px;
    font-size: 0.9em;
    display: flex;
    align-items: center;
    gap: 10px;
  }
</style>

<div class="portal-container">
  
  <%# --- HEADER DEL PORTAL --- %>
  <header class="portal-header">
    <span class="badge">Portal Oficial del Cliente</span>
    <h1 class="title-accent">El Evento de <%= @gig.client&.name || "Cliente" %></h1>
    <p>
      <span>📅 <%= @gig.date&.strftime("%d/%m/%Y") || "Fecha por definir" %></span>
      <span>•</span>
      <span>📍 <%= @gig.location.presence || "Ubicación por confirmar" %></span>
      <% if @gig.formatted_time_range.present? %>
        <span>•</span>
        <span>🕐 <%= @gig.formatted_time_range %></span>
      <% end %>
    </p>
  </header>

  <%# --- CUENTA REGRESIVA --- %>
  <section class="glass-card">
    <h2 class="countdown-title" id="countdown-label">Tiempo Restante para el Evento</h2>
    <div class="countdown-container">
      <div class="countdown-box">
        <div class="val" id="cd-days">--</div>
        <div class="lbl">Días</div>
      </div>
      <div class="countdown-box">
        <div class="val" id="cd-hours">--</div>
        <div class="lbl">Horas</div>
      </div>
      <div class="countdown-box">
        <div class="val" id="cd-minutes">--</div>
        <div class="lbl">Minutos</div>
      </div>
      <div class="countdown-box">
        <div class="val" id="cd-seconds">--</div>
        <div class="lbl">Segundos</div>
      </div>
    </div>
  </section>

  <%# --- RESUMEN DE CONTRATO / CONDICIONES --- %>
  <section class="glass-card">
    <h2 class="section-title">
      <span class="icon">📜</span>
      Resumen de Contrato y Condiciones
    </h2>
    
    <% if @gig.details.present? %>
      <div class="contract-content">
        <%= @gig.details %>
      </div>
    <% else %>
      <div class="alert-warning" style="margin-bottom: 20px;">
        ℹ️ Los detalles del paquete contratado se están terminando de redactar. Pronto aparecerán aquí.
      </div>
    <% end %>

    <%# Panel de Firma Digital %>
    <div id="signature-section">
      <% if @gig.contract_signed? %>
        <div class="signed-badge">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path>
            <polyline points="22 4 12 14.01 9 11.01"></polyline>
          </svg>
          <div class="signed-details">
            <h4 style="margin: 0 0 5px 0; font-size: 1.05em; font-weight: 800;">Contrato Firmado Digitalmente</h4>
            <p><strong>Firmante:</strong> <%= @gig.contract_signed_name %></p>
            <p><strong>Fecha/Hora:</strong> <%= @gig.contract_signed_at&.strftime("%d/%m/%Y %I:%M %p") %></p>
            <p><strong>IP de Registro:</strong> <%= @gig.contract_signed_ip %></p>
          </div>
        </div>
      <% else %>
        <div class="alert-warning">
          ⚠️ El contrato se encuentra pendiente de aprobación. Por favor, lee los términos detallados arriba y fírmalo digitalmente escribiendo tu nombre completo.
        </div>
        <div class="signature-box">
          <label style="display: block; font-weight: 700; font-size: 0.85em; text-transform: uppercase; color: var(--text-muted); margin-bottom: 8px;">Firma Digital del Cliente</label>
          <input type="text" id="signature-input" placeholder="Escribe tu nombre completo para firmar..." class="form-input">
          <button id="btn-sign-contract" onclick="submitContractSignature()" class="btn-portal">
            ✍️ Aceptar Términos y Firmar Contrato
          </button>
        </div>
      <% end %>
    </div>
  </section>

  <%# --- EQUIPO DE TRABAJO --- %>
  <% if @staff_members.present? %>
  <section class="glass-card">
    <h2 class="section-title">
      <span class="icon">👥</span>
      Tu Equipo de Trabajo
    </h2>
    <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); gap: 20px;">
      <% @staff_members.each do |staff| %>
        <%= link_to public_portal_worker_path(token: @gig.portal_token, worker_id: staff.id), style: "text-decoration: none; color: inherit; display: block;" do %>
          <div style="background: rgba(255, 255, 255, 0.03); border: 1px solid rgba(255, 255, 255, 0.06); border-radius: 16px; padding: 20px; text-align: center; height: 100%; box-sizing: border-box; transition: border-color 0.3s, transform 0.3s; cursor: pointer;" onmouseover="this.style.borderColor='rgba(139,92,246,0.3)'; this.style.transform='translateY(-3px)';" onmouseout="this.style.borderColor='rgba(255,255,255,0.06)'; this.style.transform='translateY(0)';">
            <% if staff.avatar.attached? %>
              <div style="width: 80px; height: 80px; border-radius: 50%; margin: 0 auto 12px; overflow: hidden; border: 3px solid rgba(139, 92, 246, 0.3); box-shadow: 0 0 15px rgba(139, 92, 246, 0.15); display: flex; align-items: center; justify-content: center;">
                <%= image_tag staff.avatar, style: "width: 100%; height: 100%; object-fit: cover;" %>
              </div>
            <% else %>
              <div style="width: 80px; height: 80px; border-radius: 50%; margin: 0 auto 12px; background: linear-gradient(135deg, #8b5cf6 0%, #06b6d4 100%); display: flex; align-items: center; justify-content: center; font-family: var(--font-outfit); font-size: 1.6em; font-weight: 800; color: white; border: 3px solid rgba(139, 92, 246, 0.3); box-shadow: 0 0 15px rgba(139, 92, 246, 0.15);">
                <%= staff.display_name[0].upcase %>
              </div>
            <% end %>
            <h4 style="margin: 0 0 4px 0; font-family: var(--font-outfit); font-weight: 700; font-size: 1.05em; color: var(--text-main);">
              <%= staff.display_name %>
            </h4>
            <% if staff.specialty.present? %>
              <span style="display: inline-block; background: rgba(139, 92, 246, 0.12); border: 1px solid rgba(139, 92, 246, 0.25); color: #c084fc; padding: 3px 10px; border-radius: 99px; font-size: 0.78em; font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 8px;">
                <%= staff.specialty %>
              </span>
            <% end %>
            <% if staff.bio.present? %>
              <p style="margin: 8px 0 0 0; color: var(--text-muted); font-size: 0.85em; line-height: 1.4; display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden; text-overflow: ellipsis;">
                <%= staff.bio %>
              </p>
            <% end %>
          </div>
        <% end %>
      <% end %>
    </div>
  </section>
  <% end %>

  <%# --- ESTADO DE CUENTA / PAGOS --- %>
  <section class="glass-card">
    <h2 class="section-title">
      <span class="icon">💳</span>
      Estado de Cuenta y Pagos
    </h2>

    <div class="finance-grid">
      <div class="finance-card val-total">
        <div class="lbl">Total Acordado</div>
        <div class="val"><%= number_with_precision(@gig.amount, precision: 2) %> <span style="font-size:0.6em; color:var(--text-muted);"><%= @gig.currency %></span></div>
      </div>
      <div class="finance-card val-paid">
        <div class="lbl">Total Abonado</div>
        <div class="val"><%= number_with_precision(@gig.total_received || 0, precision: 2) %> <span style="font-size:0.6em; color:var(--text-muted);"><%= @gig.currency %></span></div>
      </div>
      <div class="finance-card val-remaining">
        <div class="lbl">Saldo Pendiente</div>
        <div class="val"><%= number_with_precision(@gig.remaining_amount || 0, precision: 2) %> <span style="font-size:0.6em; color:var(--text-muted);"><%= @gig.currency %></span></div>
      </div>
    </div>

    <%# Progress bar %>
    <% pct = (@gig.total_received.to_f / (@gig.amount.to_f.nonzero? || 1) * 100).to_f %>
    <div class="progress-container">
      <div class="progress-header">
        <span style="color: var(--text-muted);">Progreso de Pago</span>
        <span style="color: #22d3ee;"><%= pct.round(1) %>% Cobrado</span>
      </div>
      <div class="progress-track">
        <div class="progress-fill" style="width: <%= [pct, 100].min %>%;"></div>
      </div>
    </div>

    <%# Historial de transacciones %>
    <h3 style="font-family: var(--font-outfit); font-size: 1.05em; font-weight: 700; margin: 0 0 15px 0; text-transform: uppercase; letter-spacing: 0.5px; color: var(--text-muted);">Historial de Transacciones</h3>
    <% if @gig_payments.any? %>
      <div class="table-wrapper">
        <table class="portal-table">
          <thead>
            <tr>
              <th>Fecha</th>
              <th>Payer / Cliente</th>
              <th>Concepto / Referencia</th>
              <th style="text-align: right;">Monto</th>
            </tr>
          </thead>
          <tbody>
            <% @gig_payments.each do |p| %>
              <tr>
                <td style="color: var(--text-muted); font-weight: 600;"><%= p.date_paid&.strftime("%d/%m/%Y") || "---" %></td>
                <td style="font-weight: 600; color: var(--text-main);"><%= p.payer_name.presence || "Cliente" %></td>
                <td style="color: var(--text-muted); font-size: 0.9em;">
                  <span style="background: rgba(255,255,255,0.06); padding: 2px 6px; border-radius: 4px; font-weight: 700; font-size: 0.8em; color: var(--text-main); margin-right: 5px;">
                    <%= p.category.presence || "Abono" %>
                  </span>
                  <%= p.notes %>
                </td>
                <td style="text-align: right; font-weight: 800; color: var(--success);">
                  +<%= number_with_precision(p.amount, precision: 2) %> <%= p.currency %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% else %>
      <p style="text-align: center; color: var(--text-muted); font-style: italic; margin: 20px 0;">No se han registrado pagos para este show todavía.</p>
    <% end %>

    <%# Reportar nuevo pago %>
    <% if @gig.remaining_amount.positive? %>
      <div style="margin-top: 30px; border-top: 1px dashed rgba(255, 255, 255, 0.08); padding-top: 25px;">
        <p style="font-size: 0.9em; color: var(--text-muted); text-align: center; margin-bottom: 15px;">
          ¿Realizaste un nuevo abono? Envíanos tu comprobante o capture por WhatsApp para que nuestro equipo lo registre.
        </p>
        <%
          whatsapp_number = "584140000000" # Por defecto o configurado si existe
          if @gig.client&.formatted_phone_for_whatsapp.present?
            # En realidad queremos el WhatsApp de la EMPRESA/LÍDER, no del cliente.
            # Supongamos que hay un teléfono corporativo, si no usaremos wa.me/58414... o similar
          end
          # Usamos un texto predefinido
          wa_message = "Hola! Acabo de hacer un pago para el evento de #{@gig.client&.name} del día #{@gig.date&.strftime('%d/%m/%Y')}. Adjunto el comprobante."
          wa_url = "https://wa.me/584140000000?text=#{ERB::Util.url_encode(wa_message)}" # Teléfono placeholder, modificable
        %>
        <a href="<%= wa_url %>" target="_blank" class="btn-portal btn-whatsapp" style="text-decoration: none;">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"></path>
          </svg>
          Notificar Pago por WhatsApp
        </a>
      </div>
    <% end %>
  </section>

  <%# --- CRONOGRAMA / TIMELINE --- %>
  <section class="glass-card">
    <h2 class="section-title">
      <span class="icon">📅</span>
      Cronograma y Agenda del Evento
    </h2>

    <% if @timeline_items.any? %>
      <div class="timeline-container">
        <% @timeline_items.each do |item| %>
          <div class="timeline-item">
