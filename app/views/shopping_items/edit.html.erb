<div style="max-width: 820px; margin: 0 auto; font-family: 'Inter', sans-serif;">

  <%# Encabezado %>
  <div style="display: flex; align-items: center; gap: 16px; margin-bottom: 36px; padding-bottom: 20px; border-bottom: 2px solid #f1f5f9;">
    <%= link_to shopping_items_path, style: "color: #64748b; text-decoration: none; font-size: 0.9em; display: flex; align-items: center; gap: 6px; padding: 8px 14px; background: #f8fafc; border: 1px solid #e2e8f0; border-radius: 10px; font-weight: 600; transition: all 0.2s;",
        onmouseover: "this.style.background='#f1f5f9'", onmouseout: "this.style.background='#f8fafc'" do %>
      ← Volver
    <% end %>
    <div>
      <h1 style="color: #0f172a; margin: 0; font-size: 1.8em; font-weight: 800;">✏️ Editar Ítem</h1>
      <p style="color: #64748b; margin: 4px 0 0 0; font-size: 0.95em;"><strong><%= @shopping_item.name %></strong></p>
    </div>
  </div>

  <%# Card del formulario %>
  <div style="background: white; border-radius: 24px; border: 1px solid #e2e8f0; padding: 36px; box-shadow: 0 8px 20px rgba(0,0,0,0.04);">
    <%= render 'form', shopping_item: @shopping_item %>
  </div>

</div>
