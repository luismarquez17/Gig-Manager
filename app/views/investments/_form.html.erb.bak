<div style="max-width: 620px; margin: 0 auto; font-family: 'Inter', 'Segoe UI', sans-serif;">

  <div style="background: white; border-radius: 24px; border: 1px solid #e2e8f0; padding: 40px; box-shadow: 0 8px 25px rgba(0,0,0,0.06);">

    <div style="margin-bottom: 30px;">
      <h2 style="margin: 0 0 6px; color: #0f172a; font-size: 1.6em; font-weight: 800;">
        <%= investment.new_record? ? "💸 Nueva Inversión" : "✏️ Editar Inversión" %>
      </h2>
      <p style="margin: 0; color: #64748b; font-size: 0.95em;">Registra un gasto o inversión del grupo musical.</p>
    </div>

    <%= form_with model: investment, local: true do |f| %>

      <% if investment.errors.any? %>
        <div style="background: #fff1f2; border: 1px solid #fca5a5; border-radius: 12px; padding: 16px; margin-bottom: 24px;">
          <p style="margin: 0 0 8px; color: #be123c; font-weight: 700;">⚠️ Por favor corrige los siguientes errores:</p>
          <ul style="margin: 0; padding-left: 20px; color: #e11d48; font-size: 0.9em;">
            <% investment.errors.full_messages.each do |msg| %>
              <li><%= msg %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <%# Descripción %>
      <div style="margin-bottom: 22px;">
        <%= f.label :description, "Descripción *", style: "display: block; font-size: 0.82em; font-weight: 700; color: #475569; text-transform: uppercase; letter-spacing: 0.4px; margin-bottom: 7px;" %>
        <%= f.text_field :description, placeholder: "Ej: Compra de monitor de escenario",
            style: "width: 100%; padding: 12px 16px; border: 1px solid #e2e8f0; border-radius: 12px; font-size: 0.95em; font-family: inherit; color: #1e293b; box-sizing: border-box; outline: none; transition: border 0.2s;",
            onfocus: "this.style.borderColor='#2563eb'", onblur: "this.style.borderColor='#e2e8f0'" %>
      </div>

      <%# Categoría %>
      <div style="margin-bottom: 22px;">
        <%= f.label :category, "Categoría *", style: "display: block; font-size: 0.82em; font-weight: 700; color: #475569; text-transform: uppercase; letter-spacing: 0.4px; margin-bottom: 7px;" %>
        <%= f.select :category, Investment::CATEGORIES,
            { prompt: "Seleccionar categoría..." },
            { style: "width: 100%; padding: 12px 16px; border: 1px solid #e2e8f0; border-radius: 12px; font-size: 0.95em; font-family: inherit; color: #1e293b; box-sizing: border-box; background: white; outline: none;" } %>
      </div>

      <%# Monto y Moneda %>
      <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin-bottom: 22px;">
        <div>
          <%= f.label :amount, "Monto *", style: "display: block; font-size: 0.82em; font-weight: 700; color: #475569; text-transform: uppercase; letter-spacing: 0.4px; margin-bottom: 7px;" %>
          <%= f.text_field :amount,
              inputmode: 'decimal',
              data: { controller: 'currency', action: 'input->currency#format blur->currency#format' },
              placeholder: "0.00",
              style: "width: 100%; padding: 12px 16px; border: 1px solid #e2e8f0; border-radius: 12px; font-size: 0.95em; font-family: inherit; color: #1e293b; box-sizing: border-box; outline: none; transition: border 0.2s;",
              onfocus: "this.style.borderColor='#2563eb'", onblur: "this.style.borderColor='#e2e8f0'" %>
        </div>
        <div>
          <%= f.label :currency, "Moneda *", style: "display: block; font-size: 0.82em; font-weight: 700; color: #475569; text-transform: uppercase; letter-spacing: 0.4px; margin-bottom: 7px;" %>
          <%= f.select :currency, [["USD ($)", "USD"], ["BS (Bolívares)", "BS"]],
              { prompt: "Seleccionar..." },
              { style: "width: 100%; padding: 12px 16px; border: 1px solid #e2e8f0; border-radius: 12px; font-size: 0.95em; font-family: inherit; color: #1e293b; box-sizing: border-box; background: white; outline: none;" } %>
        </div>
      </div>

      <%# Fecha %>
      <div style="margin-bottom: 22px;">
        <%= f.label :date, "Fecha del Gasto *", style: "display: block; font-size: 0.82em; font-weight: 700; color: #475569; text-transform: uppercase; letter-spacing: 0.4px; margin-bottom: 7px;" %>
        <%= f.date_field :date,
            style: "width: 100%; padding: 12px 16px; border: 1px solid #e2e8f0; border-radius: 12px; font-size: 0.95em; font-family: inherit; color: #1e293b; box-sizing: border-box; outline: none; transition: border 0.2s;",
            onfocus: "this.style.borderColor='#2563eb'", onblur: "this.style.borderColor='#e2e8f0'" %>
      </div>

      <%# Número de Recibo %>
      <div style="margin-bottom: 22px;">
        <%= f.label :receipt_number, "Número de Recibo / Factura", style: "display: block; font-size: 0.82em; font-weight: 700; color: #475569; text-transform: uppercase; letter-spacing: 0.4px; margin-bottom: 7px;" %>
        <%= f.text_field :receipt_number, placeholder: "Opcional — Ej: FAC-00123",
            style: "width: 100%; padding: 12px 16px; border: 1px solid #e2e8f0; border-radius: 12px; font-size: 0.95em; font-family: inherit; color: #1e293b; box-sizing: border-box; outline: none; transition: border 0.2s;",
            onfocus: "this.style.borderColor='#2563eb'", onblur: "this.style.borderColor='#e2e8f0'" %>
      </div>

      <%# Notas %>
      <div style="margin-bottom: 30px;">
        <%= f.label :notes, "Notas Adicionales", style: "display: block; font-size: 0.82em; font-weight: 700; color: #475569; text-transform: uppercase; letter-spacing: 0.4px; margin-bottom: 7px;" %>
        <%= f.text_area :notes, rows: 3, placeholder: "Opcional — detalles, proveedor, contexto...",
            style: "width: 100%; padding: 12px 16px; border: 1px solid #e2e8f0; border-radius: 12px; font-size: 0.95em; font-family: inherit; color: #1e293b; box-sizing: border-box; resize: vertical; outline: none; transition: border 0.2s;",
            onfocus: "this.style.borderColor='#2563eb'", onblur: "this.style.borderColor='#e2e8f0'" %>
      </div>

      <%# Botones %>
      <div style="display: flex; gap: 12px; justify-content: flex-end;">
        <%= link_to "Cancelar", investments_path,
            style: "padding: 13px 24px; background: #f8fafc; color: #64748b; border-radius: 12px; font-weight: 700; font-size: 0.95em; text-decoration: none; border: 1px solid #e2e8f0;" %>
        <%= f.submit investment.new_record? ? "✅ Registrar Inversión" : "💾 Guardar Cambios",
            style: "padding: 13px 28px; background: #2563eb; color: white; border: none; border-radius: 12px; font-size: 0.95em; font-weight: 800; cursor: pointer; box-shadow: 0 4px 12px rgba(37,99,235,0.3); font-family: inherit;" %>
      </div>

    <% end %>
  </div>
</div>
