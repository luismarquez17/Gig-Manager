<div style="max-width: 1200px; margin: 0 auto; font-family: 'Inter', 'Segoe UI', sans-serif;">

  <%# --- FLASH MESSAGES --- %>
  <% flash.each do |type, message| %>
    <div style="margin-bottom: 20px; padding: 14px 20px; border-radius: 12px;
        background: <%= type == 'notice' ? '#d1fae5' : '#fee2e2' %>;
        color: <%= type == 'notice' ? '#065f46' : '#991b1b' %>;
        font-weight: 600; border: 1px solid <%= type == 'notice' ? '#6ee7b7' : '#fca5a5' %>;">
      <%= message %>
    </div>
  <% end %>

  <%# --- HEADER --- %>
  <header style="display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 35px;">
    <div>
      <h1 style="color: #0f172a; font-size: 2.2em; font-weight: 800; margin: 0; letter-spacing: -0.5px;">💸 Inversiones del Grupo</h1>
      <p style="color: #64748b; font-size: 1.05em; margin-top: 6px;">Registro de gastos: equipos, transporte, marketing, local de ensayo y más.</p>
    </div>
    <div style="display: flex; gap: 12px; flex-shrink: 0;">
      <%= link_to investments_report_path, target: "_blank",
          style: "display: flex; align-items: center; gap: 8px; padding: 12px 20px; background: white; border: 1px solid #e2e8f0; color: #475569; border-radius: 12px; font-weight: 700; font-size: 0.9em; text-decoration: none;" do %>
        🖨️ Imprimir Reporte
      <% end %>
      <%= link_to new_investment_path,
          style: "display: flex; align-items: center; gap: 8px; padding: 12px 20px; background: #2563eb; color: white; border-radius: 12px; font-weight: 700; font-size: 0.9em; text-decoration: none; box-shadow: 0 4px 12px rgba(37,99,235,0.3);" do %>
        + Nueva Inversión
      <% end %>
    </div>
  </header>

  <%# --- TARJETAS DE RESUMEN --- %>
  <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 20px; margin-bottom: 35px;">

    <div style="background: linear-gradient(135deg, #10b981, #34d399); padding: 25px; border-radius: 20px; color: white; box-shadow: 0 8px 20px rgba(16,185,129,0.25);">
      <span style="font-size: 0.75em; font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px; opacity: 0.85; display: block; margin-bottom: 8px;">Total Invertido USD</span>
      <h2 style="font-size: 2em; margin: 0; font-weight: 800;">$ <%= number_with_precision(@total_usd, precision: 2, delimiter: ',') %></h2>
    </div>

    <div style="background: linear-gradient(135deg, #3b82f6, #60a5fa); padding: 25px; border-radius: 20px; color: white; box-shadow: 0 8px 20px rgba(59,130,246,0.25);">
      <span style="font-size: 0.75em; font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px; opacity: 0.85; display: block; margin-bottom: 8px;">Total Invertido BS</span>
      <h2 style="font-size: 2em; margin: 0; font-weight: 800;">Bs <%= number_with_precision(@total_bs, precision: 2, delimiter: ',') %></h2>
    </div>

    <div style="background: linear-gradient(135deg, #8b5cf6, #a78bfa); padding: 25px; border-radius: 20px; color: white; box-shadow: 0 8px 20px rgba(139,92,246,0.25);">
      <span style="font-size: 0.75em; font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px; opacity: 0.85; display: block; margin-bottom: 8px;">Total de Registros</span>
      <h2 style="font-size: 2em; margin: 0; font-weight: 800;"><%= Investment.count %></h2>
    </div>

  </div>

  <%# --- DISTRIBUCIÓN POR CATEGORÍA --- %>
  <% if @total_by_category.any? %>
    <div style="background: white; border-radius: 20px; border: 1px solid #e2e8f0; padding: 25px; margin-bottom: 30px; box-shadow: 0 4px 6px rgba(0,0,0,0.02);">
      <h3 style="margin: 0 0 20px 0; font-weight: 800; color: #1e293b; font-size: 1.1em;">📊 Distribución por Categoría (USD)</h3>
      <div style="display: flex; flex-direction: column; gap: 12px;">
        <% max_cat = @total_by_category.values.map(&:to_f).max || 1 %>
        <% cat_colors = { "Equipo" => "#2563eb", "Transporte" => "#f59e0b", "Taller / Reparación" => "#e11d48", "Marketing" => "#8b5cf6", "Local de Ensayo" => "#10b981", "Otros" => "#64748b" } %>
        <% @total_by_category.sort_by { |_, v| -v.to_f }.each do |cat, amount| %>
          <div style="display: flex; align-items: center; gap: 12px;">
            <div style="width: 130px; font-size: 0.85em; font-weight: 600; color: #475569; text-align: right; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;"><%= cat %></div>
            <div style="flex: 1; background: #f8fafc; height: 28px; border-radius: 8px; overflow: hidden; border: 1px solid #f1f5f9;">
              <div style="width: <%= [(amount.to_f / max_cat) * 100, 3].max %>%; background: <%= cat_colors[cat] || '#64748b' %>; height: 100%; border-radius: 8px; display: flex; align-items: center; padding-left: 10px; box-sizing: border-box;">
                <span style="color: white; font-weight: 700; font-size: 0.78em; white-space: nowrap;">$<%= number_with_precision(amount, precision: 0) %></span>
              </div>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>

  <%# --- FILTROS --- %>
  <div style="background: white; border-radius: 16px; border: 1px solid #e2e8f0; padding: 20px; margin-bottom: 25px;">
    <%= form_with url: investments_path, method: :get, local: true, style: "display: flex; gap: 15px; align-items: flex-end; flex-wrap: wrap;" do |f| %>
      <div>
        <label style="display: block; font-size: 0.78em; font-weight: 700; color: #64748b; margin-bottom: 5px; text-transform: uppercase; letter-spacing: 0.4px;">Categoría</label>
        <%= f.select :category,
            [["Todas las categorías", ""]] + Investment::CATEGORIES,
            {},
            { style: "padding: 10px 14px; border: 1px solid #e2e8f0; border-radius: 10px; font-family: inherit; font-size: 0.9em; color: #1e293b; background: #f8fafc; outline: none;" } %>
      </div>
      <div>
        <label style="display: block; font-size: 0.78em; font-weight: 700; color: #64748b; margin-bottom: 5px; text-transform: uppercase; letter-spacing: 0.4px;">Moneda</label>
        <%= f.select :currency,
            [["Todas las monedas", ""], ["USD", "USD"], ["BS", "BS"]],
            {},
            { style: "padding: 10px 14px; border: 1px solid #e2e8f0; border-radius: 10px; font-family: inherit; font-size: 0.9em; color: #1e293b; background: #f8fafc; outline: none;" } %>
      </div>
      <%= f.submit "Filtrar", style: "padding: 10px 20px; background: #2563eb; color: white; border: none; border-radius: 10px; font-weight: 700; font-size: 0.9em; cursor: pointer;" %>
      <% if params[:category].present? || params[:currency].present? %>
        <%= link_to "✕ Limpiar", investments_path, style: "padding: 10px 16px; background: #f1f5f9; color: #64748b; border-radius: 10px; font-weight: 600; font-size: 0.9em; text-decoration: none;" %>
      <% end %>
    <% end %>
  </div>

  <%# --- TABLA DE INVERSIONES --- %>
  <div style="background: white; border-radius: 20px; border: 1px solid #e2e8f0; overflow: hidden; box-shadow: 0 4px 6px rgba(0,0,0,0.02);">
    <% if @investments.any? %>
      <table style="width: 100%; border-collapse: collapse;">
        <thead>
          <tr style="background: #f8fafc; border-bottom: 2px solid #e2e8f0;">
            <th style="padding: 16px 20px; text-align: left; font-size: 0.75em; font-weight: 800; color: #64748b; text-transform: uppercase; letter-spacing: 0.5px;">Fecha</th>
            <th style="padding: 16px 20px; text-align: left; font-size: 0.75em; font-weight: 800; color: #64748b; text-transform: uppercase; letter-spacing: 0.5px;">Descripción</th>
            <th style="padding: 16px 20px; text-align: left; font-size: 0.75em; font-weight: 800; color: #64748b; text-transform: uppercase; letter-spacing: 0.5px;">Categoría</th>
            <th style="padding: 16px 20px; text-align: right; font-size: 0.75em; font-weight: 800; color: #64748b; text-transform: uppercase; letter-spacing: 0.5px;">Monto</th>
            <th style="padding: 16px 20px; text-align: left; font-size: 0.75em; font-weight: 800; color: #64748b; text-transform: uppercase; letter-spacing: 0.5px;">Recibo</th>
            <th style="padding: 16px 20px; text-align: center; font-size: 0.75em; font-weight: 800; color: #64748b; text-transform: uppercase; letter-spacing: 0.5px;">Acciones</th>
          </tr>
        </thead>
        <tbody>
          <% @investments.each_with_index do |inv, i| %>
            <tr style="border-bottom: 1px solid #f1f5f9; transition: background 0.2s;"
                onmouseover="this.style.background='#f8fafc'"
                onmouseout="this.style.background='white'">
              <td style="padding: 16px 20px; font-size: 0.9em; color: #64748b; font-weight: 600; white-space: nowrap;">
                <%= inv.date.strftime("%d/%m/%Y") rescue "—" %>
              </td>
              <td style="padding: 16px 20px;">
                <div style="font-weight: 700; color: #1e293b; font-size: 0.95em;"><%= inv.description %></div>
                <% if inv.notes.present? %>
                  <small style="color: #94a3b8; font-size: 0.8em;"><%= truncate(inv.notes, length: 60) %></small>
                <% end %>
              </td>
              <td style="padding: 16px 20px;">
                <% badge_color = { "Equipo" => "#dbeafe:#2563eb", "Transporte" => "#fef3c7:#d97706", "Taller / Reparación" => "#fee2e2:#e11d48", "Marketing" => "#ede9fe:#7c3aed", "Local de Ensayo" => "#d1fae5:#059669", "Otros" => "#f1f5f9:#64748b" }[inv.category] || "#f1f5f9:#64748b" %>
                <% bg, fg = badge_color.split(":") %>
                <span style="background: <%= bg %>; color: <%= fg %>; padding: 4px 12px; border-radius: 8px; font-size: 0.78em; font-weight: 700;">
                  <%= inv.category %>
                </span>
              </td>
              <td style="padding: 16px 20px; text-align: right; font-weight: 800; font-size: 1em; color: <%= inv.currency == 'USD' ? '#10b981' : '#3b82f6' %>; white-space: nowrap;">
                <%= inv.currency == 'USD' ? '$ ' : 'Bs ' %><%= number_with_precision(inv.amount, precision: 2, delimiter: ',') %>
              </td>
              <td style="padding: 16px 20px; font-size: 0.85em; color: #94a3b8; font-weight: 600;">
                <%= inv.receipt_number.present? ? inv.receipt_number : "—" %>
              </td>
              <td style="padding: 16px 20px; text-align: center;">
                <div style="display: flex; gap: 8px; justify-content: center;">
                  <%= link_to edit_investment_path(inv),
                      style: "padding: 6px 14px; background: #eff6ff; color: #2563eb; border-radius: 8px; font-size: 0.8em; font-weight: 700; text-decoration: none;" do %>
                    ✏️ Editar
                  <% end %>
                  <%= button_to investment_path(inv), method: :delete,
                      data: { turbo_confirm: "¿Eliminar esta inversión?" },
                      style: "padding: 6px 14px; background: #fff1f2; color: #e11d48; border: none; border-radius: 8px; font-size: 0.8em; font-weight: 700; cursor: pointer;" do %>
                    🗑️
                  <% end %>
                </div>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    <% else %>
      <div style="text-align: center; padding: 60px 20px; color: #94a3b8;">
        <div style="font-size: 3em; margin-bottom: 15px;">💸</div>
        <p style="font-weight: 600; font-size: 1.1em; margin: 0 0 8px;">No hay inversiones registradas</p>
        <small>Haz clic en "+ Nueva Inversión" para empezar a registrar gastos del grupo.</small>
      </div>
    <% end %>
  </div>

</div>
