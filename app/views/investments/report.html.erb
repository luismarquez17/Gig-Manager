<!DOCTYPE html>
<html>
  <head>
    <title>Reporte de Inversiones — Gig Manager</title>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800&display=swap" rel="stylesheet">
    <style>
      * { box-sizing: border-box; margin: 0; padding: 0; }
      body { font-family: 'Inter', sans-serif; background: white; color: #1e293b; padding: 40px; }

      .report-header { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 35px; padding-bottom: 25px; border-bottom: 3px solid #0f172a; }
      .report-logo { display: flex; align-items: center; gap: 12px; }
      .report-logo-icon { background: #2563eb; color: white; width: 42px; height: 42px; display: flex; align-items: center; justify-content: center; border-radius: 10px; font-size: 1.2em; font-weight: 800; }
      .report-title h1 { font-size: 1.6em; font-weight: 800; letter-spacing: -0.5px; }
      .report-title p { color: #64748b; font-size: 0.85em; margin-top: 3px; }
      .report-meta { text-align: right; color: #64748b; font-size: 0.85em; }
      .report-meta strong { color: #1e293b; font-size: 1em; display: block; margin-bottom: 3px; }

      .section-title { font-size: 1em; font-weight: 800; color: #1e293b; margin-bottom: 14px; text-transform: uppercase; letter-spacing: 0.5px; }

      /* Resumen financiero */
      .summary-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 16px; margin-bottom: 35px; }
      .summary-card { background: #f8fafc; border: 1px solid #e2e8f0; border-radius: 14px; padding: 18px; }
      .summary-card .label { font-size: 0.72em; font-weight: 700; text-transform: uppercase; letter-spacing: 0.4px; color: #64748b; margin-bottom: 8px; }
      .summary-card .value { font-size: 1.5em; font-weight: 800; }
      .summary-card.green .value { color: #059669; }
      .summary-card.blue .value { color: #2563eb; }
      .summary-card.red .value { color: #e11d48; }
      .summary-card.purple .value { color: #7c3aed; }

      /* Tabla */
      table { width: 100%; border-collapse: collapse; margin-bottom: 30px; font-size: 0.88em; }
      thead tr { background: #0f172a; color: white; }
      thead th { padding: 12px 14px; text-align: left; font-size: 0.72em; text-transform: uppercase; letter-spacing: 0.5px; font-weight: 700; }
      tbody tr { border-bottom: 1px solid #f1f5f9; }
      tbody tr:nth-child(even) { background: #f8fafc; }
      tbody td { padding: 11px 14px; color: #334155; }
      .amount-cell { text-align: right; font-weight: 700; }
      .category-badge { background: #e2e8f0; color: #475569; padding: 3px 9px; border-radius: 6px; font-size: 0.78em; font-weight: 700; white-space: nowrap; }

      /* Pie de tabla */
      tfoot tr { border-top: 2px solid #0f172a; background: #f0f4ff; }
      tfoot td { padding: 13px 14px; font-weight: 800; font-size: 0.95em; }

      /* ROI Section */
      .roi-box { border: 2px solid #0f172a; border-radius: 14px; padding: 25px; margin-top: 10px; }
      .roi-grid { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 20px; }
      .roi-item { text-align: center; }
      .roi-item .label { font-size: 0.75em; font-weight: 700; color: #64748b; text-transform: uppercase; letter-spacing: 0.4px; margin-bottom: 8px; }
      .roi-item .value { font-size: 1.8em; font-weight: 800; }
      .roi-separator { width: 1px; background: #e2e8f0; }

      .print-btn { position: fixed; bottom: 30px; right: 30px; background: #2563eb; color: white; border: none; padding: 14px 24px; border-radius: 14px; font-weight: 800; font-size: 1em; cursor: pointer; box-shadow: 0 8px 20px rgba(37,99,235,0.35); font-family: inherit; display: flex; align-items: center; gap: 8px; }

      @media print {
        body { padding: 20px; }
        .print-btn { display: none !important; }
        .no-print { display: none !important; }
      }
    </style>
  </head>
  <body>

    <%# HEADER %>
    <div class="report-header">
      <div class="report-logo">
        <div class="report-logo-icon">G</div>
        <div class="report-title">
          <h1>Gig Manager</h1>
          <p>Reporte de Inversiones y Retorno</p>
        </div>
      </div>
      <div class="report-meta">
        <strong>Fecha del Reporte</strong>
        <%= @report_date.strftime("%d de %B de %Y") %>
      </div>
    </div>

    <%# RESUMEN FINANCIERO EN 4 TARJETAS %>
    <div style="margin-bottom: 14px;" class="section-title">📊 Resumen Financiero</div>
    <div class="summary-grid">
      <div class="summary-card red">
        <div class="label">Total Invertido (USD)</div>
        <div class="value">$ <%= number_with_precision(@total_usd, precision: 2, delimiter: ',') %></div>
      </div>
      <div class="summary-card blue">
        <div class="label">Total Facturado Gigs (USD)</div>
        <div class="value">$ <%= number_with_precision(@total_billed_usd, precision: 2, delimiter: ',') %></div>
      </div>
      <div class="summary-card <%= @net_gain >= 0 ? 'green' : 'red' %>">
        <div class="label">Ganancia Neta (USD)</div>
        <div class="value"><%= @net_gain >= 0 ? '+ ' : '- ' %>$ <%= number_with_precision(@net_gain.abs, precision: 2, delimiter: ',') %></div>
      </div>
      <div class="summary-card purple">
        <div class="label">% Retorno sobre Inversión</div>
        <div class="value"><%= number_with_precision(@roi_pct, precision: 1) %>%</div>
      </div>
    </div>

    <%# TABLA DE INVERSIONES %>
    <div style="margin-bottom: 14px;" class="section-title">💸 Detalle de Inversiones</div>
    <table>
      <thead>
        <tr>
          <th>Fecha</th>
          <th>Descripción</th>
          <th>Categoría</th>
          <th>Moneda</th>
          <th style="text-align: right;">Monto</th>
          <th>Recibo</th>
        </tr>
      </thead>
      <tbody>
        <% @investments.each do |inv| %>
          <tr>
            <td><%= inv.date.strftime("%d/%m/%Y") rescue "—" %></td>
            <td>
              <%= inv.description %>
              <% if inv.notes.present? %>
                <br><small style="color: #94a3b8; font-size: 0.82em;"><%= inv.notes %></small>
              <% end %>
            </td>
            <td><span class="category-badge"><%= inv.category %></span></td>
            <td style="font-weight: 700;"><%= inv.currency %></td>
            <td class="amount-cell"><%= inv.currency == 'USD' ? '$ ' : 'Bs ' %><%= number_with_precision(inv.amount, precision: 2, delimiter: ',') %></td>
            <td style="color: #94a3b8;"><%= inv.receipt_number.present? ? inv.receipt_number : "—" %></td>
          </tr>
        <% end %>
      </tbody>
      <tfoot>
        <tr>
          <td colspan="4" style="text-align: right;">TOTAL INVERTIDO:</td>
          <td class="amount-cell" style="color: #e11d48;">$ <%= number_with_precision(@total_usd, precision: 2, delimiter: ',') %> USD</td>
          <td></td>
        </tr>
        <% if @total_bs > 0 %>
        <tr>
          <td colspan="4" style="text-align: right;"></td>
          <td class="amount-cell" style="color: #2563eb;">Bs <%= number_with_precision(@total_bs, precision: 2, delimiter: ',') %> BS</td>
          <td></td>
        </tr>
        <% end %>
      </tfoot>
    </table>

    <%# CAJA DE ROI %>
    <div class="roi-box">
      <div class="section-title" style="margin-bottom: 20px;">📈 Análisis de Retorno (ROI)</div>
      <div class="roi-grid">
        <div class="roi-item">
          <div class="label">Total Invertido</div>
          <div class="value" style="color: #e11d48;">$ <%= number_with_precision(@total_usd, precision: 2) %></div>
          <div style="font-size: 0.78em; color: #94a3b8; margin-top: 4px;">En USD</div>
        </div>
        <div class="roi-separator"></div>
        <div class="roi-item">
          <div class="label">Total Facturado en Gigs</div>
          <div class="value" style="color: #2563eb;">$ <%= number_with_precision(@total_billed_usd, precision: 2) %></div>
          <div style="font-size: 0.78em; color: #94a3b8; margin-top: 4px;">En USD</div>
        </div>
        <div class="roi-separator"></div>
        <div class="roi-item">
          <div class="label">Ganancia Neta / ROI</div>
          <div class="value" style="color: <%= @net_gain >= 0 ? '#059669' : '#e11d48' %>;">
            <%= @net_gain >= 0 ? '+' : '' %><%= number_with_precision(@roi_pct, precision: 1) %>%
          </div>
          <div style="font-size: 0.78em; color: #94a3b8; margin-top: 4px;">
            <%= @net_gain >= 0 ? '+' : '' %>$ <%= number_with_precision(@net_gain, precision: 2) %> USD
          </div>
        </div>
      </div>
    </div>

    <%# BOTÓN IMPRIMIR %>
    <button class="print-btn no-print" onclick="window.print()">
      🖨️ Imprimir / Guardar PDF
    </button>

  </body>
</html>
