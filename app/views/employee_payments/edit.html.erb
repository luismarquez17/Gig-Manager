<h2 style="margin-bottom:18px;">✏️ Editar Pago a Trabajador</h2>

<div class="custom-card">
  <% if @payment.errors.any? %>
    <div style="margin-bottom: 12px; padding: 10px; border-radius: 6px; background: #fff1f2; color: #981b1b; border: 1px solid #fecaca;">
      <strong>No se pudo actualizar el pago:</strong>
      <ul style="margin: 6px 0 0 16px;">
        <% @payment.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <%= form_with model: @payment, local: true do |f| %>
    <div class="form-group-custom">
      <%= f.label :user_id, 'Trabajador' %>
      <%= f.collection_select :user_id, User.workers.order(:email), :id, :display_name, { include_blank: true }, { class: 'form-input-custom' } %>
    </div>

    <div class="form-group-custom">
      <%= f.label :gig_id, 'Relacionado a show (opcional)' %>
      <%= f.collection_select :gig_id, Gig.order(date: :desc), :id, ->(g) { "#{g.client.name} - #{g.date}" }, { include_blank: true }, { class: 'form-input-custom' } %>
      <small style="color: #64748b; font-size: 0.85em;">Si cambias el show, los fondos de nómina anteriores se revertirán y se recalcularán con el nuevo monto.</small>
    </div>

    <div class="form-group-custom">
      <%= f.label :amount, 'Monto pagado' %>
      <%= f.text_field :amount,
        inputmode: 'decimal',
        class: 'form-input-custom',
        placeholder: '0.00' %>
    </div>

    <div class="form-group-custom">
      <%= f.label :expected_amount, 'Monto esperado (opcional)' %>
      <%= f.text_field :expected_amount,
        inputmode: 'decimal',
        class: 'form-input-custom',
        placeholder: '0.00' %>
    </div>

    <div class="form-group-custom">
      <%= f.label :currency %>
      <%= f.text_field :currency, class: 'form-input-custom' %>
    </div>

    <div class="form-group-custom">
      <%= f.label :date_paid %>
      <%= f.date_field :date_paid, class: 'form-input-custom' %>
    </div>

    <div class="form-group-custom">
      <%= f.label :payment_method %>
      <%= f.text_field :payment_method, class: 'form-input-custom' %>
    </div>

    <div class="form-group-custom">
      <%= f.label :notes %>
      <%= f.text_area :notes, class: 'form-input-custom', rows: 4 %>
    </div>

    <div style="margin-top:12px; display: flex; gap: 10px;">
      <%= link_to 'Cancelar', employee_payments_path(user_id: @payment.user_id), class: 'btn-main btn-gray-custom' %>
      <%= f.submit '💾 Guardar Cambios', class: 'btn-main btn-primary-custom' %>
    </div>
  <% end %>
</div>
