<!DOCTYPE html>
<html>
  <head>
    <title>GigManager</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800&display=swap" rel="stylesheet">
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
    <style>
      /* Hide native scrollbar but keep scroll functionality */
      aside {
        /* allow flex children to shrink/overflow correctly */
        min-height: 0;
      }
      aside nav {
        scrollbar-width: none; /* Firefox */
        -ms-overflow-style: none; /* IE 10+ */
        position: relative; /* container for custom indicator */
        /* ensure nav can scroll inside the flex layout */
        min-height: 0;
        overflow-y: auto;
        -webkit-overflow-scrolling: touch;
      }
      aside nav::-webkit-scrollbar { display: none; }

      /* Custom scroll indicator (a subtle background bar acting as thumb) */
      #sidebar-scroll-indicator {
        position: absolute;
        right: 6px;
        top: 0;
        width: 6px;
        background: rgba(255,255,255,0.08);
        border-radius: 6px;
        transition: transform 0.12s linear, height 0.12s linear, opacity 0.12s linear;
        will-change: transform, height;
        opacity: 0.9;
      }

      /* Prevent long labels from wrapping awkwardly */
      aside nav a { white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    </style>
  </head>

  <body style="margin: 0; padding: 0; background-color: #f8fafc;">
    <div style="display: flex; min-height: 100vh; font-family: 'Inter', sans-serif;">
      
      <%# --- MOSTRAR SIDEBAR SOLO SI HAY USUARIO --- %>
      <% if user_signed_in? %>
        <aside class="app-sidebar">
          
          <%# Logo %>
          <div class="sidebar-brand">
            <h2>
              <span class="brand-logo">G</span>
              Gig Manager
            </h2>
          </div>

          <%# Navegación %>
          <nav class="sidebar-nav">
            <%= link_to root_path, class: "sidebar-link #{'active' if controller_name == 'pages' && action_name == 'dashboard'}" do %>
              <span class="icon">🏠</span> <span>Inicio (Dashboard)</span>
            <% end %>

            <% if current_user.leader? %>
              <%= link_to items_path, class: "sidebar-link #{'active' if controller_name == 'items'}" do %>
                <span class="icon">📦</span> <span>Inventario</span>
              <% end %>

              <%= link_to clients_path, class: "sidebar-link #{'active' if controller_name == 'clients'}" do %>
                <span class="icon">👥</span> <span>Clientes</span>
              <% end %>

              <%= link_to preset_budgets_path, class: "sidebar-link #{'active' if controller_name == 'preset_budgets'}" do %>
                <span class="icon">📄</span> <span>Presupuestos Base</span>
              <% end %>


              <%= link_to gigs_path, class: "sidebar-link #{'active' if controller_name == 'gigs' && action_name != 'my'}" do %>
                <span class="icon">🎸</span> <span>Gigs / Eventos</span>
              <% end %>

              <%= link_to gig_payments_path, class: "sidebar-link #{'active' if controller_name == 'gig_payments'}" do %>
                <span class="icon">💳</span> <span>Pagos Eventos / Shows</span>
              <% end %>

              <%= link_to kits_path, class: "sidebar-link #{'active' if controller_name == 'kits'}" do %>
                <span class="icon">🛠️</span> <span>Plantillas (Kits)</span>
              <% end %>

              <%= link_to maintenance_records_path, class: "sidebar-link #{'active' if controller_name == 'maintenance_records'}" do %>
                <span class="icon">🔧</span> <span>Taller (Reparos)</span>
              <% end %>

              <%= link_to availability_dashboard_path, class: "sidebar-link #{'active' if controller_name == 'pages' && action_name == 'availability'}" do %>
                <span class="icon">⚡</span> <span>Conflictos</span>
              <% end %>

              <%= link_to financials_dashboard_path, class: "sidebar-link #{'active' if controller_name == 'pages' && action_name == 'financials'}" do %>
                <span class="icon">📊</span> <span>Métricas / Finanzas</span>
              <% end %>

              <%= link_to investments_path, class: "sidebar-link #{'active' if controller_name == 'investments'}" do %>
                <span class="icon">💸</span> <span>Inversiones</span>
              <% end %>

              <%= link_to employee_payments_path, class: "sidebar-link #{'active' if controller_name == 'employee_payments'}" do %>
                <span class="icon">💰</span> <span>Pagos a trabajadores</span>
              <% end %>

              <%= link_to users_path, class: "sidebar-link #{'active' if controller_name == 'users'}" do %>
                <span class="icon">⚙️</span> <span>Roles / Accesos</span>
              <% end %>

            <% elsif current_user.staff? %>
              <div class="nav-header">Agrupación</div>
              <%= link_to my_gigs_path, class: "sidebar-link #{'active' if controller_name == 'gigs' && action_name == 'my'}" do %>
                <span class="icon">🎫</span> <span>Mis eventos</span>
              <% end %>

              <%= link_to edit_user_registration_path, class: "sidebar-link #{'active' if current_page?(edit_user_registration_path)}" do %>
                <span class="icon">👤</span> <span>Perfil</span>
              <% end %>

              <%= link_to help_path, class: "sidebar-link #{'active' if controller_name == 'pages' && action_name == 'help'}" do %>
                <span class="icon">❓</span> <span>Ayuda</span>
              <% end %>
            <% elsif current_user.client? %>
              <div class="nav-header">Cliente</div>
              <%= link_to client_gigs_path, class: "sidebar-link #{'active' if controller_path == 'client/gigs' && action_name == 'index'}" do %>
                <span class="icon">🎫</span> <span>Mis Eventos</span>
              <% end %>

              <%# Acceso rápido al próximo evento %>
              <%
                next_gig = current_user.client&.gigs&.where('date >= ?', Date.today)&.order(date: :asc)&.first
              %>
              <% if next_gig %>
                <%= link_to client_gig_path(next_gig), class: "sidebar-link #{'active' if controller_path == 'client/gigs' && action_name == 'show'}" do %>
                  <span class="icon">⭐</span> <span>Mi Próximo Show</span>
                <% end %>
              <% end %>

              <%= link_to edit_user_registration_path, class: "sidebar-link #{'active' if current_page?(edit_user_registration_path)}" do %>
                <span class="icon">👤</span> <span>Perfil</span>
              <% end %>

              <%= link_to help_path, class: "sidebar-link #{'active' if controller_name == 'pages' && action_name == 'help'}" do %>
                <span class="icon">❓</span> <span>Ayuda</span>
              <% end %>
            <% end %>
            <div id="sidebar-scroll-indicator" aria-hidden="true"></div>
          </nav>

          <%# Pie del Sidebar: Usuario y Logout %>
          <div class="sidebar-footer">
            <div class="user-info">
              <div class="avatar">
                <%= current_user.email[0].upcase %>
              </div>
              <div class="user-details">
                <p class="email"><%= current_user.email %></p>
                <p class="status">En línea</p>
              </div>
            </div>
            <%= button_to "Cerrar Sesión", destroy_user_session_path, method: :delete, class: "btn-logout" %>
          </div>
        </aside>
      <% end %>

      <%# --- CONTENIDO PRINCIPAL --- %>
      <main style="<%= user_signed_in? ? 'margin-left: 280px;' : 'margin-left: 0;' %> flex-grow: 1; min-height: 100vh; padding: 40px; box-sizing: border-box; overflow-x: auto;">
        <div style="max-width: 1200px; margin: 0 auto;">
          <%= yield %>
        </div>
      </main>

    </div>
    <script>
      document.addEventListener('DOMContentLoaded', function(){
        var nav = document.querySelector('aside nav');
        var indicator = document.getElementById('sidebar-scroll-indicator');
        if(!nav || !indicator) return;

        function refresh(){
          var scrollHeight = nav.scrollHeight;
          var client = nav.clientHeight;
          if(scrollHeight <= client){
            indicator.style.opacity = '0';
            return;
          }
          indicator.style.opacity = '0.9';
          var thumbPct = (client / scrollHeight) * 100; // percent height
          var ratio = nav.scrollTop / (scrollHeight - client);
          var translatePct = ratio * (100 - thumbPct);
          indicator.style.height = thumbPct + '%';
          indicator.style.top = translatePct + '%';
        }

        nav.addEventListener('scroll', refresh, { passive: true });
        window.addEventListener('resize', refresh);
        // init
        refresh();
      });
    </script>
  </body>
</html>