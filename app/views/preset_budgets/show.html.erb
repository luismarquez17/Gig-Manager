<div style="max-width: 900px; margin: 0 auto; font-family: 'Inter', sans-serif;">
  
  <div style="margin-bottom: 25px; display: flex; justify-content: space-between; align-items: flex-end; flex-wrap: wrap; gap: 15px;">
    <div>
      <%= link_to '⬅ Volver al listado', preset_budgets_path, style: "color: #64748b; text-decoration: none; font-weight: bold; font-size: 0.9em; margin-bottom: 10px; display: inline-block;" %>
      <h1 style="color: #1e293b; margin: 0; font-weight: 800; font-size: 2em; letter-spacing: -0.5px;"><%= @preset_budget.title %></h1>
    </div>
    
    <div style="display: flex; gap: 10px;">
      <%= link_to '🖨️ Vista de Impresión / PDF', print_preset_budget_path(@preset_budget), target: '_blank', style: "background: #f1f5f9; color: #334155; border: 1px solid #cbd5e1; padding: 10px 18px; border-radius: 8px; text-decoration: none; font-weight: bold; font-size: 0.9em; display: flex; align-items: center; gap: 6px; transition: 0.2s;", onmouseover: "this.style.background='#e2e8f0'", onmouseout: "this.style.background='#f1f5f9'" %>
      <% unless current_user.client? %>
        <%= link_to '⚙️ Editar', edit_preset_budget_path(@preset_budget), style: "background: #2563eb; color: white; padding: 10px 18px; border-radius: 8px; text-decoration: none; font-weight: bold; font-size: 0.9em; display: flex; align-items: center; gap: 6px; transition: 0.2s;", onmouseover: "this.style.background='#1d4ed8'", onmouseout: "this.style.background='#2563eb'" %>
      <% end %>
    </div>
  </div>

  <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 30px; margin-bottom: 40px; align-items: start; flex-wrap: wrap;">
    
    <%# Columna izquierda: Imagen o flyer %>
    <div style="background: white; border: 1px solid #e2e8f0; border-radius: 16px; padding: 15px; box-shadow: 0 4px 15px rgba(0,0,0,0.02); display: flex; justify-content: center; align-items: center; min-height: 250px;">
      <% if @preset_budget.image.attached? %>
        <%= image_tag @preset_budget.image, style: "max-width: 100%; height: auto; border-radius: 10px; max-height: 450px; object-fit: contain; box-shadow: 0 4px 10px rgba(0,0,0,0.05);" %>
      <% else %>
        <div style="text-align: center; color: #94a3b8; padding: 60px 20px;">
          <div style="font-size: 80px; margin-bottom: 15px;">🖼️</div>
          <p style="margin: 0; font-weight: bold;">Sin Imagen o Flyer Cargado</p>
          <% unless current_user.client? %>
            <p style="margin: 5px 0 0 0; font-size: 0.85em; color: #cbd5e1;">Puedes editar este presupuesto para subir una imagen promocional.</p>
          <% end %>
        </div>
      <% end %>
    </div>

    <%# Columna derecha: Detalles %>
    <div style="display: flex; flex-direction: column; gap: 20px;">
      
      <div style="background: white; border: 1px solid #e2e8f0; border-radius: 16px; padding: 25px; box-shadow: 0 4px 15px rgba(0,0,0,0.02);">
        <p style="margin: 0; color: #64748b; font-size: 0.85em; font-weight: 800; text-transform: uppercase; letter-spacing: 0.5px;">Precio del Paquete</p>
        <h2 style="margin: 5px 0 0 0; color: #10b981; font-size: 2.2em; font-weight: 800;">
          $<%= number_with_precision(@preset_budget.price, precision: 2) %> 
          <span style="font-size: 0.55em; color: #94a3b8; font-weight: bold; vertical-align: middle;"><%= @preset_budget.currency %></span>
        </h2>
      </div>

      <div style="background: white; border: 1px solid #e2e8f0; border-radius: 16px; padding: 25px; box-shadow: 0 4px 15px rgba(0,0,0,0.02); flex-grow: 1;">
        <p style="margin: 0 0 15px 0; color: #64748b; font-size: 0.85em; font-weight: 800; text-transform: uppercase; letter-spacing: 0.5px; border-bottom: 1px solid #f1f5f9; padding-bottom: 10px;">📋 Descripción del Servicio</p>
        <div style="color: #334155; line-height: 1.7; font-size: 1.05em; white-space: pre-line;">
          <%= @preset_budget.description %>
        </div>
      </div>

    </div>

  </div>

  <%# --- SECCIÓN PREMIUM DE ADICIONALES PARA CLIENTES --- %>
  <% if current_user.client? %>
    <div style="margin-top: 40px; border-top: 1px solid #e2e8f0; padding-top: 30px;">
      <h3 style="color: #0f172a; font-size: 1.3em; font-weight: 800; margin: 0 0 5px 0;">🚀 Potencia tu Evento con Adicionales</h3>
      <p style="color: #64748b; font-size: 0.95em; margin: 0 0 25px 0;">Lleva la experiencia de tu show al siguiente nivel contratando nuestros servicios y efectos especiales recomendados.</p>
      
      <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 20px;">
        
        <%# Sparkulars Upsell %>
        <div style="background: white; border: 1px solid #e2e8f0; border-radius: 16px; padding: 20px; box-shadow: 0 4px 10px rgba(0,0,0,0.02); display: flex; flex-direction: column; justify-content: space-between; transition: all 0.2s;" onmouseover="this.style.transform='translateY(-3px)'; this.style.borderColor='#3b82f6';" onmouseout="this.style.transform='none'; this.style.borderColor='#e2e8f0';">
          <div>
            <span style="font-size: 2em; display: block; margin-bottom: 10px;">✨</span>
            <h4 style="margin: 0; font-size: 1.1em; font-weight: bold; color: #0f172a;">Máquina de Sparkulas</h4>
            <p style="margin: 8px 0 0 0; font-size: 0.88em; color: #475569; line-height: 1.4;">
              Alquila esta máquina de sparkulas (fuego frío) por 6 horas por tan solo 30 dólares adicionales a tu precio total. Totalmente segura para interiores.
            </p>
          </div>
          <div style="margin-top: 15px; border-top: 1px solid #f1f5f9; padding-top: 15px; display: flex; justify-content: space-between; align-items: center;">
            <span style="font-weight: 800; color: #10b981;">+$30 USD</span>
            <% wa_spark = "Hola! Me gustaría añadir la máquina de sparkulas por $30 USD adicionales al paquete #{@preset_budget.title} para mi evento." %>
            <a href="https://wa.me/584140000000?text=<%= ERB::Util.url_encode(wa_spark) %>" target="_blank" style="background: #e0f2fe; color: #0369a1; text-decoration: none; padding: 6px 12px; border-radius: 8px; font-weight: bold; font-size: 0.85em; transition: 0.2s;" onmouseover="this.style.background='#bae6fd'" onmouseout="this.style.background='#e0f2fe'">
              Añadir ＋
            </a>
          </div>
        </div>

        <%# Extra Time Upsell %>
        <div style="background: white; border: 1px solid #e2e8f0; border-radius: 16px; padding: 20px; box-shadow: 0 4px 10px rgba(0,0,0,0.02); display: flex; flex-direction: column; justify-content: space-between; transition: all 0.2s;" onmouseover="this.style.transform='translateY(-3px)'; this.style.borderColor='#3b82f6';" onmouseout="this.style.transform='none'; this.style.borderColor='#e2e8f0';">
          <div>
            <span style="font-size: 2em; display: block; margin-bottom: 10px;">🎵</span>
            <h4 style="margin: 0; font-size: 1.1em; font-weight: bold; color: #0f172a;">Horas Extra de Música</h4>
            <p style="margin: 8px 0 0 0; font-size: 0.88em; color: #475569; line-height: 1.4;">
              Extiende la diversión del show 2 horas más con música continua en vivo por solo $40 USD adicionales a tu precio total acordado.
            </p>
          </div>
          <div style="margin-top: 15px; border-top: 1px solid #f1f5f9; padding-top: 15px; display: flex; justify-content: space-between; align-items: center;">
            <span style="font-weight: 800; color: #10b981;">+$40 USD</span>
            <% wa_time = "Hola! Me gustaría añadir 2 horas extra de música por $40 USD adicionales al paquete #{@preset_budget.title} para mi evento." %>
            <a href="https://wa.me/584140000000?text=<%= ERB::Util.url_encode(wa_time) %>" target="_blank" style="background: #e0f2fe; color: #0369a1; text-decoration: none; padding: 6px 12px; border-radius: 8px; font-weight: bold; font-size: 0.85em; transition: 0.2s;" onmouseover="this.style.background='#bae6fd'" onmouseout="this.style.background='#e0f2fe'">
              Añadir ＋
            </a>
          </div>
        </div>

        <%# Sound Upgrade Upsell %>
        <div style="background: white; border: 1px solid #e2e8f0; border-radius: 16px; padding: 20px; box-shadow: 0 4px 10px rgba(0,0,0,0.02); display: flex; flex-direction: column; justify-content: space-between; transition: all 0.2s;" onmouseover="this.style.transform='translateY(-3px)'; this.style.borderColor='#3b82f6';" onmouseout="this.style.transform='none'; this.style.borderColor='#e2e8f0';">
          <div>
            <span style="font-size: 2em; display: block; margin-bottom: 10px;">🔊</span>
            <h4 style="margin: 0; font-size: 1.1em; font-weight: bold; color: #0f172a;">Subwoofer Premium 18"</h4>
            <p style="margin: 8px 0 0 0; font-size: 0.88em; color: #475569; line-height: 1.4;">
              Añade un subwoofer activo de 18 pulgadas para lograr unos bajos potentes, nítidos y envolventes que harán vibrar a todos tus invitados.
            </p>
          </div>
          <div style="margin-top: 15px; border-top: 1px solid #f1f5f9; padding-top: 15px; display: flex; justify-content: space-between; align-items: center;">
            <span style="font-weight: 800; color: #10b981;">+$25 USD</span>
            <% wa_sub = "Hola! Me gustaría añadir el subwoofer premium de 18 pulgadas por $25 USD adicionales al paquete #{@preset_budget.title} para mi evento." %>
            <a href="https://wa.me/584140000000?text=<%= ERB::Util.url_encode(wa_sub) %>" target="_blank" style="background: #e0f2fe; color: #0369a1; text-decoration: none; padding: 6px 12px; border-radius: 8px; font-weight: bold; font-size: 0.85em; transition: 0.2s;" onmouseover="this.style.background='#bae6fd'" onmouseout="this.style.background='#e0f2fe'">
              Añadir ＋
            </a>
          </div>
        </div>

      </div>
    </div>
  <% end %>

</div>
