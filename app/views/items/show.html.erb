<div style="max-width: 800px; margin: 40px auto; font-family: 'Inter', 'Segoe UI', sans-serif; padding: 0 20px;">
  
  <%# Botón Volver %>
  <%= link_to items_path, style: "text-decoration: none; color: #64748b; display: flex; align-items: center; gap: 8px; margin-bottom: 20px; font-weight: 600;" do %>
    ← Volver al Inventario
  <% end %>

  <div style="background: white; border-radius: 24px; border: 1px solid #e2e8f0; overflow: hidden; box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.1);">
    
    <%# Encabezado %>
    <% 
      status_color = case @item.status
                     when 'Excelente' then '#10b981'
                     when 'Operativo' then '#f59e0b'
                     when 'Dañado' then '#ef4444'
                     else '#64748b' 
                     end
    %>
    <div style="background: <%= status_color %>; padding: 40px; text-align: center; color: white;">
      <span style="background: rgba(255,255,255,0.2); padding: 6px 16px; border-radius: 20px; font-size: 0.9em; font-weight: bold; text-transform: uppercase;">
        <%= @item.category %>
      </span>
      <h1 style="margin: 15px 0 0 0; font-size: 2.5em; font-weight: 800;"><%= @item.name %></h1>
    </div>

    <div style="padding: 40px;">
      <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 30px;">
        
        <%# Columna Izquierda: Datos Técnicos %>
        <div>
          <h3 style="color: #94a3b8; font-size: 0.8em; text-transform: uppercase; letter-spacing: 1px; margin-bottom: 15px;">Detalles Técnicos</h3>
          
          <div style="margin-bottom: 20px;">
            <p style="margin: 0; color: #64748b; font-size: 0.9em;">Subcategoría / Tipo</p>
            <p style="margin: 5px 0 0 0; color: #1e293b; font-weight: 700; font-size: 1.2em;">
              <% if @item.sub_category.present? %>
                <%# Si es un cable o luz con tipo específico %>
                🔌 <%= @item.sub_category %>
              <% else %>
                <%# Respaldo: Si no tiene subcategoría, muestra la categoría principal %>
                📦 <%= @item.category %>
              <% end %>
            </p>
          </div>

          <div style="margin-bottom: 20px;">
            <p style="margin: 0; color: #64748b; font-size: 0.9em;">Stock Disponible</p>
            <p style="margin: 5px 0 0 0; color: #1e293b; font-weight: 700; font-size: 1.2em;">✖️ <%= @item.quantity %> unidades</p>
          </div>
        </div>

        <%# Columna Derecha: Estado %>
        <div>
          <h3 style="color: #94a3b8; font-size: 0.8em; text-transform: uppercase; letter-spacing: 1px; margin-bottom: 15px;">Estado Actual</h3>
          
          <div style="display: inline-block; padding: 10px 20px; border-radius: 12px; background: <%= status_color %>15; border: 1px solid <%= status_color %>;">
            <span style="color: <%= status_color %>; font-weight: 800; font-size: 1.2em;">
               <%= @item.status %>
            </span>
          </div>

          <% if @item.status == 'Dañado' %>
            <div style="margin-top: 20px; padding: 15px; background: #fff1f2; border: 2px dashed #ef4444; border-radius: 12px;">
              <p style="margin: 0; color: #b91c1c; font-weight: 700; font-size: 0.9em; line-height: 1.4;">
                ⚠️ RECORDATORIO:<br>Este equipo debe estar marcado con tirro.
              </p>
            </div>
          <% end %>
        </div>
      </div>

      <%# Notas Adicionales (Aparecen solo si existen) %>
      <% if @item.notes.present? %>
        <div style="margin-top: 30px; padding: 20px; background: #f8fafc; border-radius: 16px; border: 1px solid #e2e8f0;">
          <h4 style="margin: 0 0 10px 0; color: #64748b; font-size: 0.8em; text-transform: uppercase; letter-spacing: 1px;">📝 Notas y Observaciones</h4>
          <p style="margin: 0; color: #1e293b; line-height: 1.6; font-size: 1em;"><%= @item.notes %></p>
        </div>
      <% end %>

      <%# --- BOTONES DE ACCIÓN --- %>
      <div style="margin-top: 40px; padding-top: 30px; border-top: 1px solid #f1f5f9; display: flex; gap: 15px;">
        <%= link_to edit_item_path(@item), style: "flex: 3; text-align: center; background: #2563eb; color: white; padding: 18px; border-radius: 14px; text-decoration: none; font-weight: bold; box-shadow: 0 4px 12px rgba(37, 99, 235, 0.2); font-size: 1.1em;" do %>
          📝 Editar Información
        <% end %>
        
        <%= link_to item_path(@item), data: { turbo_method: :delete, turbo_confirm: "¿Estás seguro de eliminar este equipo del inventario?" }, style: "flex: 1; text-align: center; padding: 18px; background: #fff1f2; color: #e11d48; border-radius: 14px; text-decoration: none; font-weight: bold; border: 1px solid #ffe4e6;" do %>
          🗑️
        <% end %>
      </div>
    </div>
  </div>
</div>