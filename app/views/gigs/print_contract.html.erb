<!DOCTYPE html>
<html>
<head>
  <title>Contrato de Servicio: <%= @gig.client&.name %></title>
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <style>
    body {
      font-family: 'Helvetica Neue', Arial, sans-serif;
      color: #333;
      margin: 40px;
      line-height: 1.6;
      background: white;
    }

    .no-print-bar {
      display: flex;
      justify-content: space-between;
      align-items: center;
      background: #f8fafc;
      padding: 15px 30px;
      border-radius: 10px;
      border: 1px solid #e2e8f0;
      margin-bottom: 40px;
    }

    .btn-print {
      background-color: #22c55e;
      color: white;
      text-decoration: none;
      font-weight: bold;
      padding: 12px 24px;
      border-radius: 8px;
      border: none;
      cursor: pointer;
      font-size: 15px;
      box-shadow: 0 4px 6px rgba(34, 197, 94, 0.2);
      transition: 0.2s;
    }

    .btn-print:hover {
      background-color: #16a34a;
    }

    .btn-back {
      color: #64748b;
      text-decoration: none;
      font-weight: bold;
      font-size: 0.95em;
    }

    .document-container {
      max-width: 800px;
      margin: 0 auto;
      border: 1px solid #e2e8f0;
      padding: 50px;
      border-radius: 12px;
      box-shadow: 0 4px 15px rgba(0,0,0,0.02);
    }

    .header-table {
      width: 100%;
      border-collapse: collapse;
      margin-bottom: 40px;
      border-bottom: 2px solid #0f172a;
      padding-bottom: 20px;
    }

    .logo-area {
      font-size: 26px;
      font-weight: 800;
      color: #0f172a;
      letter-spacing: -0.5px;
    }

    .logo-sub {
      font-size: 14px;
      color: #64748b;
      font-weight: normal;
      margin-top: 5px;
    }

    .doc-meta {
      text-align: right;
      font-size: 14px;
      color: #475569;
    }

    .title-banner {
      background: #f8fafc;
      padding: 20px;
      border-radius: 8px;
      margin-bottom: 30px;
      border-left: 5px solid #2563eb;
    }

    .title-banner h2 {
      margin: 0;
      color: #0f172a;
      font-size: 22px;
    }

    .description-box {
      font-size: 16px;
      color: #334155;
      margin-bottom: 40px;
      white-space: pre-line;
      padding: 10px 0;
    }

    .total-box {
      background: #0f172a;
      color: white;
      padding: 25px;
      border-radius: 8px;
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-top: 30px;
    }

    .total-title {
      font-size: 16px;
      font-weight: bold;
      text-transform: uppercase;
      letter-spacing: 0.5px;
      color: #94a3b8;
    }

    .total-amount {
      font-size: 28px;
      font-weight: 800;
      color: #22c55e;
    }

    .signature-section {
      margin-top: 60px;
      display: flex;
      justify-content: space-between;
    }

    .signature-box {
      width: 45%;
      text-align: center;
    }

    .signature-line {
      border-bottom: 1px solid #0f172a;
      height: 60px;
      margin-bottom: 10px;
    }

    .footer-note {
      text-align: center;
      margin-top: 50px;
      font-size: 12px;
      color: #94a3b8;
      border-top: 1px dashed #e2e8f0;
      padding-top: 20px;
    }

    @media print {
      body { margin: 0; padding: 0; }
      .no-print { display: none !important; }
      .document-container {
        border: none !important;
        box-shadow: none !important;
        padding: 20px !important;
        max-width: 100% !important;
      }
      .total-box {
        background: #eee !important;
        color: #000 !important;
        border: 1px solid #000 !important;
        -webkit-print-color-adjust: exact;
        print-color-adjust: exact;
      }
      .total-title { color: #333 !important; }
      .total-amount { color: #000 !important; }
      .title-banner {
        background: #f5f5f5 !important;
        border-left-color: #000 !important;
        -webkit-print-color-adjust: exact;
        print-color-adjust: exact;
      }
    }
  </style>
</head>
<body>

  <div class="no-print-bar no-print">
    <a href="javascript:window.close();" class="btn-back">⬅️ Cerrar Ventana</a>
    <span style="font-weight: bold; color: #475569;">📄 Vista previa de contrato</span>
    <button class="btn-print" onclick="window.print()">🖨️ Imprimir Contrato</button>
  </div>

  <div class="document-container">
    
    <table class="header-table">
      <tr>
        <td class="logo-area">
          🔊 GIG MANAGER
          <div class="logo-sub">Servicios Profesionales de Producción y Sonido</div>
        </td>
        <td class="doc-meta">
          <strong>CONTRATO DE SERVICIO</strong><br>
          Fecha: <%= Time.zone.now.strftime("%d/%m/%Y") %><br>
          Evento del: <%= @gig.date&.strftime("%d/%m/%Y") %>
        </td>
      </tr>
    </table>

    <div class="title-banner">
      <p style="margin: 0 0 5px 0; font-size: 12px; font-weight: bold; color: #64748b; text-transform: uppercase; letter-spacing: 0.5px;">CLIENTE</p>
      <h2><%= @gig.client&.name %></h2>
      <p style="margin: 5px 0 0 0; font-size: 14px; color: #475569;">
        📍 <strong>Locación:</strong> <%= @gig.location.presence || "Por definir" %><br>
        🕒 <strong>Horario:</strong> <%= @gig.start_time&.strftime("%I:%M %p") %> - <%= @gig.end_time&.strftime("%I:%M %p") %>
      </p>
    </div>

    <div style="font-weight: bold; font-size: 14px; text-transform: uppercase; letter-spacing: 0.5px; color: #64748b; margin-bottom: 10px; border-bottom: 1px solid #f1f5f9; padding-bottom: 5px;">
      Detalles del Servicio
    </div>
    
    <div class="description-box">
      <%= @gig.details.presence || "No hay detalles adicionales especificados para este evento." %>
    </div>

    <% if @gig.gig_items.any? %>
      <div style="font-weight: bold; font-size: 14px; text-transform: uppercase; letter-spacing: 0.5px; color: #64748b; margin-bottom: 15px; border-bottom: 1px solid #f1f5f9; padding-bottom: 5px;">
        Equipos Involucrados
      </div>
      <ul style="margin-bottom: 30px; color: #334155; padding-left: 20px;">
        <% @gig.gig_items.includes(:item).each do |gi| %>
          <li><%= gi.quantity %>x <%= gi.item.name %></li>
        <% end %>
      </ul>
    <% end %>

    <div class="total-box">
      <span class="total-title">Total Acordado</span>
      <span class="total-amount">
        <%= number_to_currency(@gig.amount, unit: @gig.currency == "USD" ? "$" : "Bs. ", precision: 2) %>
      </span>
    </div>

    <div class="signature-section">
      <div class="signature-box">
        <div class="signature-line"></div>
        <strong>Firma del Cliente</strong><br>
        <%= @gig.client&.name %>
      </div>
      <div class="signature-box">
        <div class="signature-line"></div>
        <strong>Firma del Proveedor</strong><br>
        Gig Manager
      </div>
    </div>

    <div class="footer-note">
      Al firmar este documento, ambas partes aceptan las condiciones y detalles descritos anteriormente.<br>
      Generado digitalmente por Gig Manager
    </div>

  </div>

</body>
</html>
