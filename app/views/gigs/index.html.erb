<div style="max-width: 1200px; margin: 0 auto; font-family: 'Segoe UI', sans-serif;">
  
  <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 25px;">
    <h1 style="color: #2c3e50; margin: 0;">🎸 Historial de Toques</h1>
    <%= link_to '➕ Registrar Nuevo Toque', new_gig_path, style: "background: #28a745; color: white; padding: 12px 20px; text-decoration: none; border-radius: 8px; font-weight: bold; box-shadow: 0 4px 6px rgba(40, 167, 69, 0.2);" %>
  </div>

  <%# --- SECCIÓN DE BÚSQUEDA, FILTROS Y ORDEN --- %>
  <div style="background: white; padding: 25px; border-radius: 12px; box-shadow: 0 2px 15px rgba(0,0,0,0.05); margin-bottom: 30px; border: 1px solid #eee;">
    <%= form_with url: gigs_path, method: :get, local: true, style: "display: flex; gap: 15px; align-items: flex-end; flex-wrap: wrap;" do |f| %>
      
      <%# Buscador %>
      <div style="flex-grow: 2; min-width: 200px; margin-bottom: 20px;">
        <%= f.label :query, "🔍 Buscar Cliente o Teléfono", style: "display: block; font-size: 0.85em; font-weight: bold; margin-bottom: 8px; color: #555;" %>
        <%= f.text_field :query, value: params[:query], placeholder: "Ej: Juan Perez o 0414...", style: "width: 100%; padding: 10px; border: 1px solid #ddd; border-radius: 6px; box-sizing: border-box;" %>
      </div>

      <%# Filtro de Prioridad %>
      <div style="flex-grow: 1; min-width: 150px; margin-bottom: 20px;">
        <%= f.label :priority, "Prioridad", style: "display: block; font-size: 0.85em; font-weight: bold; margin-bottom: 8px; color: #555;" %>
        <%= f.select :priority, [["Todas", ""], ["Alta 🟢", "alta"], ["Media 🟡", "media"], ["Baja 🔴", "baja"]], { selected: params[:priority] }, { style: "width: 100%; padding: 10px; border: 1px solid #ddd; border-radius: 6px; background: white;" } %>
      </div>

      <%# Filtro de Fecha %>
      <div style="flex-grow: 1; min-width: 150px; margin-bottom: 20px;">
        <%= f.label :date_filter, "Fecha", style: "display: block; font-size: 0.85em; font-weight: bold; margin-bottom: 8px; color: #555;" %>
        <%= f.select :date_filter, [["Todos", ""], ["Próximos 🔮", "upcoming"], ["Pasados ⏳", "past"]], { selected: params[:date_filter] }, { style: "width: 100%; padding: 10px; border: 1px solid #ddd; border-radius: 6px; background: white;" } %>
      </div>

      <%# Selector de Ordenamiento %>
      <div style="flex-grow: 1; min-width: 180px; margin-bottom: 20px;">
        <%= f.label :sort, "📊 Ordenar por", style: "display: block; font-size: 0.85em; font-weight: bold; margin-bottom: 8px; color: #555;" %>
        <%= f.select :sort, 
            [["📅 Fecha (Reciente)", "fecha_desc"], 
             ["💰 Monto (Mayor a Menor)", "monto_desc"], 
             ["💸 Monto (Menor a Mayor)", "monto_asc"]], 
            { selected: params[:sort] }, 
            { style: "width: 100%; padding: 10px; border: 1px solid #ddd; border-radius: 6px; background: white;" } %>
      </div>

      <%# Botones de Acción %>
      <div style="display: flex; gap: 10px; margin-bottom: 20px; align-items: flex-end;">
        <%= f.submit "Aplicar", style: "background: #007bff; color: white; border: none; padding: 0 25px; border-radius: 6px; cursor: pointer; font-weight: bold; height: 40px;" %>
        
        <%# Botón Limpiar mejorado con color Gris Oscuro / Antracita %>
        <%= link_to "Limpiar", gigs_path, style: "background: #4a5568; color: white; border: none; padding: 0 15px; border-radius: 6px; text-decoration: none; font-size: 0.9em; display: flex; align-items: center; height: 40px; font-weight: bold;" %>
      </div>
    <% end %>
  </div>

  <%# --- TABLA DE RESULTADOS --- %>
  <div style="background: white; border-radius: 12px; overflow: hidden; box-shadow: 0 4px 6px rgba(0,0,0,0.05); border: 1px solid #eee;">
    <% if @gigs.any? %>
      <table style="width: 100%; border-collapse: collapse; text-align: left;">
        <thead>
          <tr style="background-color: #f8f9fa; color: #333;">
            <th style="padding: 15px; border-bottom: 2px solid #eee;">Fecha</th>
            <th style="padding: 15px; border-bottom: 2px solid #eee;">Cliente (Prioridad)</th>
            <th style="padding: 15px; border-bottom: 2px solid #eee;">Ubicación & Detalles</th>
            <th style="padding: 15px; border-bottom: 2px solid #eee;">Monto</th>
            <th style="padding: 15px; border-bottom: 2px solid #eee;">Moneda</th>
            <th style="padding: 15px; border-bottom: 2px solid #eee; text-align: center;">Acciones</th>
          </tr>
        </thead>
        <tbody>
          <% @gigs.each do |gig| %>
            <tr style="border-bottom: 1px solid #f1f1f1;" onmouseover="this.style.backgroundColor='#fdfdfd'" onmouseout="this.style.backgroundColor='transparent'">
              <td style="padding: 15px; color: #666;"><%= gig.date.strftime("%d/%m/%Y") if gig.date %></td>
              <td style="padding: 15px;">
                <div style="display: flex; align-items: center; gap: 10px;">
                  <% if gig.client %>
                    <div style="width: 12px; height: 12px; border-radius: 50%; background: <%= color_prioridad(gig.client.priority) %>; flex-shrink: 0;"></div>
                    <div>
                      <%= link_to gig.client.name, client_path(gig.client), style: "color: #007bff; text-decoration: none; font-weight: bold; display: block;" %>
                      <small style="color: #999;"><%= gig.client.phone %></small>
                    </div>
                  <% else %>
                    <div style="width: 12px; height: 12px; border-radius: 50%; background: #94a3b8; flex-shrink: 0;"></div>
                    <div>
                      <span style="color: #64748b; font-weight: bold; display: block;">Sin Cliente</span>
                      <small style="color: #cbd5e1;"><%= gig.client_email %></small>
                    </div>
                  <% end %>
                </div>
              </td>
              <td style="padding: 15px; color: #555;">
                <div style="font-weight: bold; color: #334155; margin-bottom: 4px;">
                  <%= gig.location.presence || "---" %>
                </div>
                <% if gig.details.present? %>
                  <div style="font-size: 0.85em; color: #64748b; line-height: 1.4;" title="<%= gig.details %>">
                    <%= truncate(gig.details, length: 80) %>
                  </div>
                <% end %>
              </td>
              <td style="padding: 15px; font-weight: bold; color: #2c3e50;"><%= number_with_precision(gig.amount, precision: 2) %></td>
              <td style="padding: 15px;">
                <span style="background: #eef2f7; padding: 4px 10px; border-radius: 6px; font-size: 0.8em; font-weight: bold; color: #475569; border: 1px solid #e2e8f0;">
                  <%= gig.currency %>
                </span>
              </td>
              <td style="padding: 15px; text-align: center;">
                <div style="display: flex; justify-content: center; gap: 15px;">
                  
                  <%# NUEVO Botón de Ver Evento (Panel/Checklist) %>
                  <%= link_to gig_path(gig), 
                      style: "background: #f0fdf4; border: 1px solid #86efac; padding: 10px 16px; border-radius: 8px; cursor: pointer; display: flex; align-items: center; gap: 8px; text-decoration: none; transition: 0.2s; box-shadow: 0 2px 4px rgba(22, 101, 52, 0.05);", 
                      onmouseover: "this.style.backgroundColor='#dcfce7'",
                      onmouseout: "this.style.backgroundColor='#f0fdf4'",
                      title: "Ver Detalles y Checklist" do %>
                    <span style="color: #166534; font-size: 0.9em; font-weight: bold;">Checklist</span>
                    <span style="font-size: 1.1em;">✅</span>
                  <% end %>

                  <%# NUEVO Botón de Eliminar estilizado %>
                  <%= button_to gig_path(gig), 
                      method: :delete, 
                      data: { turbo_confirm: "¿Estás seguro de que quieres eliminar este show? Esto recalculará la prioridad del cliente." }, 
                      style: "background: #fff5f5; border: 1px solid #feb2b2; padding: 10px 16px; border-radius: 8px; cursor: pointer; display: flex; align-items: center; gap: 8px; transition: 0.2s; box-shadow: 0 2px 4px rgba(197, 48, 48, 0.05);", 
                      onmouseover: "this.style.backgroundColor='#fed7d7'",
                      onmouseout: "this.style.backgroundColor='#fff5f5'",
                      title: "Eliminar Registro" do %>
                    <span style="color: #c53030; font-size: 0.9em; font-weight: bold;">Eliminar</span>
                    <span style="font-size: 1.1em;">🗑️</span>
                  <% end %>
                </div>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    <% else %>
      <div style="padding: 60px 20px; text-align: center; color: #94a3b8;">
        <div style="font-size: 50px; margin-bottom: 10px;">🤷‍♂️</div>
        <h3 style="margin: 0; color: #64748b;">No se encontraron shows registrados</h3>
        <%= link_to "Ver todos los shows", gigs_path, style: "display: inline-block; margin-top: 20px; color: #007bff; text-decoration: none; font-weight: bold;" %>
      </div>
    <% end %>
  </div>

  <%# --- RESUMEN DINÁMICO --- %>
  <% if @gigs.any? %>
    <div style="margin-top: 30px; padding: 25px; background: #ffffff; border-radius: 12px; border: 1px solid #eee; display: flex; justify-content: space-between; align-items: center;">
      <div>
        <h3 style="margin: 0; color: #64748b; font-size: 0.9em; text-transform: uppercase; letter-spacing: 1px;">Balance Filtrado</h3>
        <p style="margin: 5px 0 0 0; font-size: 1.5em; font-weight: bold;">
          <span style="color: #10b981;">$ <%= number_with_precision(@total_usd, precision: 2) %></span>
          <span style="color: #cbd5e1; margin: 0 15px;">|</span>
          <span style="color: #3b82f6;">Bs <%= number_with_precision(@total_bs, precision: 2) %></span>
        </p>
      </div>
      <div style="text-align: right; color: #94a3b8; font-size: 0.9em;">
        Resultados: <strong><%= @gigs.count %></strong> shows
      </div>
    </div>
  <% end %>

</div>